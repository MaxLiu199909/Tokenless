#!/usr/bin/env node
'use strict';

const path = require('path');
const fs = require('fs');
const { spawn } = require('child_process');
const os = require('os');

const { isNoisyCommand, getReducerForCommand, getReducerForOutput } = require('../lib/classify');
const { compactOutput, estimateTokens } = require('../lib/compact');
const {
  createArtifact,
  readArtifact,
  listArtifacts,
  expandArtifactAround,
  formatArtifactPointer
} = require('../lib/artifact_store');

function usage() {
  console.log('Usage:');
  console.log('  acc run --agent --data-dir <dir> -- <command>');
  console.log('  acc run --agent --data-dir <dir> --cmd-b64 <base64-shell-command>');
  console.log('  acc compact --type <reducer> --data-dir <dir> --stdin');
  console.log('  acc doctor --data-dir <dir>');
  console.log('  acc status --user|--project [--settings <path>]');
  console.log('  acc print-hooks [--data-dir <dir>]');
  console.log('  acc install-hooks --user|--project [--settings <path>] [--dry-run]');
  console.log('  acc uninstall-hooks --user|--project [--settings <path>] [--dry-run]');
  console.log('  acc list --data-dir <dir> [--limit <n>]');
  console.log('  acc latest --data-dir <dir>');
  console.log('  acc show <artifact_id> --data-dir <dir>');
  console.log('  acc expand <artifact_id|latest> --around <keyword> --data-dir <dir>');
  console.log('  acc clean --data-dir <dir> [--keep <n>] [--older-than <7d|24h|60m>] [--dry-run]');
}

function stripQuotes(value) {
  if (typeof value !== 'string') {
    return value;
  }

  const startsSingle = value.startsWith("'") && value.endsWith("'");
  const startsDouble = value.startsWith('"') && value.endsWith('"');
  if (value.length >= 2 && (startsSingle || startsDouble)) {
    return value.slice(1, -1);
  }
  return value;
}

function parseShowOrExpandArgs(args) {
  let around;
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.acc');
  const positional = [];

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    if (arg === '--data-dir') {
      dataDir = stripQuotes(args[i + 1]);
      i += 1;
      continue;
    }
    if (arg === '--around') {
      around = args[i + 1];
      i += 1;
      continue;
    }
    if (arg === '--') {
      continue;
    }
    positional.push(arg);
  }

  return { dataDir, around, positional };
}

function parseRunArgs(argv) {
  let i = 0;
  let agent = false;
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.acc');
  let encodedCommand = null;

  while (i < argv.length) {
    const arg = argv[i];
    if (arg === '--agent') {
      agent = true;
      i += 1;
      continue;
    }
    if (arg === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 2;
      continue;
    }
    if (arg === '--cmd-b64') {
      encodedCommand = Buffer.from(String(argv[i + 1] || ''), 'base64').toString('utf8');
      i += 2;
      continue;
    }
    if (arg === '--') {
      i += 1;
      break;
    }
    i += 1;
  }

  const commandParts = argv.slice(i);
  return { agent, dataDir, commandParts, encodedCommand };
}

function parseCompactArgs(argv) {
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.acc');
  let reducer = null;
  let stdin = false;
  let commandLabel = 'stdin';
  let exitCode = 0;

  for (let i = 0; i < argv.length; i++) {
    const arg = argv[i];
    if (arg === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (arg === '--type') {
      reducer = argv[i + 1];
      i += 1;
      continue;
    }
    if (arg === '--stdin') {
      stdin = true;
      continue;
    }
    if (arg === '--command') {
      commandLabel = argv[i + 1];
      i += 1;
      continue;
    }
    if (arg === '--exit-code') {
      exitCode = Number(argv[i + 1]) || 0;
      i += 1;
      continue;
    }
  }

  return { dataDir, reducer, stdin, commandLabel, exitCode };
}

function parseDoctorArgs(argv) {
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.acc');
  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
    }
  }
  return { dataDir };
}

function parseListArgs(argv) {
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.acc');
  let limit = 20;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--limit') {
      limit = Math.max(1, Number(argv[i + 1]) || limit);
      i += 1;
    }
  }

  return { dataDir, limit };
}

function parseCleanArgs(argv) {
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.acc');
  let keep = null;
  let olderThan = null;
  let dryRun = false;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--keep') {
      keep = Math.max(0, Number(argv[i + 1]) || 0);
      i += 1;
      continue;
    }
    if (argv[i] === '--older-than') {
      olderThan = String(argv[i + 1] || '');
      i += 1;
      continue;
    }
    if (argv[i] === '--dry-run') {
      dryRun = true;
    }
  }

  return { dataDir, keep, olderThan, dryRun };
}

function parseInstallHooksArgs(argv) {
  let scope = null;
  let settingsPath = null;
  let dryRun = false;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--project') {
      scope = 'project';
      continue;
    }
    if (argv[i] === '--user') {
      scope = 'user';
      continue;
    }
    if (argv[i] === '--settings') {
      settingsPath = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--dry-run') {
      dryRun = true;
    }
  }

  return { scope, settingsPath, dryRun };
}

function parseSettingsScopeArgs(argv) {
  let scope = null;
  let settingsPath = null;
  let dryRun = false;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--user') {
      scope = 'user';
      continue;
    }
    if (argv[i] === '--project') {
      scope = 'project';
      continue;
    }
    if (argv[i] === '--settings') {
      settingsPath = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--dry-run') {
      dryRun = true;
    }
  }

  return { scope, settingsPath, dryRun };
}

function okLine(label, value) {
  console.log(`[ok] ${label}: ${value}`);
}

function failLine(label, value) {
  console.log(`[fail] ${label}: ${value}`);
}

function checkReadableJson(label, filePath) {
  try {
    JSON.parse(fs.readFileSync(filePath, 'utf8'));
    okLine(label, filePath);
    return true;
  } catch (err) {
    failLine(label, `${filePath} (${err.message})`);
    return false;
  }
}

function runDoctor(dataDir) {
  const pluginRoot = path.resolve(__dirname, '..');
  const hooksPath = path.join(pluginRoot, 'hooks', 'hooks.json');
  const manifestPath = path.join(pluginRoot, '.claude-plugin', 'plugin.json');
  const preToolPath = path.join(pluginRoot, 'scripts', 'pre_tool_use.js');
  const postToolPath = path.join(pluginRoot, 'scripts', 'post_tool_use.js');
  const userSettingsPath = path.join(os.homedir(), '.claude', 'settings.json');

  console.log('ACC-DOCTOR/0.1');
  console.log('');
  okLine('node', process.version);
  okLine('acc cli', __filename);
  okLine('plugin root', pluginRoot);
  okLine('CLAUDE_PLUGIN_ROOT', process.env.CLAUDE_PLUGIN_ROOT || '(not set)');
  okLine('CLAUDE_PLUGIN_DATA', process.env.CLAUDE_PLUGIN_DATA || '(not set)');

  checkReadableJson('plugin manifest', manifestPath);
  checkReadableJson('hooks json', hooksPath);

  for (const filePath of [preToolPath, postToolPath]) {
    if (fs.existsSync(filePath)) okLine('script exists', filePath);
    else failLine('script exists', filePath);
  }

  try {
    fs.mkdirSync(dataDir, { recursive: true });
    const testPath = path.join(dataDir, '.acc-doctor-write-test');
    fs.writeFileSync(testPath, 'ok\n', 'utf8');
    fs.unlinkSync(testPath);
    okLine('data dir writable', dataDir);
  } catch (err) {
    failLine('data dir writable', `${dataDir} (${err.message})`);
  }

  const sampleCommand = Buffer.from('npm run build', 'utf8').toString('base64');
  const sampleRewrite = `node '${__filename.replace(/'/g, "'\\''")}' run --agent --data-dir '${dataDir.replace(/'/g, "'\\''")}' --cmd-b64 '${sampleCommand}'`;
  okLine('sample PreToolUse rewrite', sampleRewrite);

  if (fs.existsSync(userSettingsPath)) {
    try {
      const userSettings = JSON.parse(fs.readFileSync(userSettingsPath, 'utf8'));
      const status = getHookInstallStatus(userSettings);
      okLine('user settings readable', userSettingsPath);
      okLine('user hooks installed', status.installed ? 'yes' : 'no');
    } catch (err) {
      failLine('user settings readable', `${userSettingsPath} (${err.message})`);
    }
  } else {
    failLine('user settings readable', `${userSettingsPath} (not found)`);
  }
}

function resolveArtifactId(artifactId, dataDir) {
  if (artifactId !== 'latest') {
    return artifactId;
  }

  const latest = listArtifacts(dataDir)[0];
  if (!latest) {
    console.error(`no artifacts found in ${dataDir}`);
    process.exit(1);
  }

  return latest.artifact_id;
}

function printArtifactSummary(meta, index) {
  const prefix = index == null ? '' : `${String(index + 1).padStart(2, '0')}. `;
  process.stdout.write(`${prefix}${meta.artifact_id}  ${meta.status || 'unknown'}  ${meta.reducer || 'unknown'}  ${meta.created_at || 'unknown'}\n`);
  process.stdout.write(`    command: ${String(meta.command || '').slice(0, 180)}\n`);
}

function parseDurationMs(value) {
  if (!value) return null;
  const match = /^(\d+)(m|h|d)$/i.exec(String(value).trim());
  if (!match) {
    throw new Error(`invalid duration: ${value}. Use forms like 60m, 24h, or 7d.`);
  }

  const amount = Number(match[1]);
  const unit = match[2].toLowerCase();
  if (unit === 'm') return amount * 60 * 1000;
  if (unit === 'h') return amount * 60 * 60 * 1000;
  return amount * 24 * 60 * 60 * 1000;
}

function printHooks(dataDir) {
  const pluginRoot = path.resolve(__dirname, '..');
  const hooks = buildHooksObject(pluginRoot);

  console.log('ACC-HOOKS/0.1');
  console.log(`data_dir: ${dataDir}`);
  console.log('');
  console.log(JSON.stringify(hooks, null, 2));
}

function buildHooksObject(pluginRoot) {
  return {
    hooks: {
      PreToolUse: [
        {
          matcher: 'Bash',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'pre_tool_use.js')}"`
            }
          ]
        }
      ],
      PostToolUse: [
        {
          matcher: 'Bash',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'post_tool_use.js')}"`
            }
          ]
        }
      ],
      PostToolUseFailure: [
        {
          matcher: 'Bash',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'post_tool_failure.js')}"`
            }
          ]
        }
      ]
    }
  };
}

function getSettingsPath(scope, settingsPath) {
  if (settingsPath) return settingsPath;
  if (scope === 'user') return path.join(os.homedir(), '.claude', 'settings.json');
  if (scope === 'project') return path.join(process.cwd(), '.claude', 'settings.local.json');
  return null;
}

function isAccHookEntry(entry) {
  const text = JSON.stringify(entry || {}).replace(/\\/g, '/');
  return text.includes('/plugins/claude-code/scripts/pre_tool_use.js') ||
    text.includes('/plugins/claude-code/scripts/post_tool_use.js') ||
    text.includes('/plugins/claude-code/scripts/post_tool_failure.js');
}

function getHookInstallStatus(settings) {
  const hooks = settings.hooks || {};
  const expected = ['PreToolUse', 'PostToolUse', 'PostToolUseFailure'];
  const detail = {};

  for (const hookName of expected) {
    const list = Array.isArray(hooks[hookName]) ? hooks[hookName] : [];
    detail[hookName] = list.some(isAccHookEntry);
  }

  return {
    installed: expected.every((hookName) => detail[hookName]),
    detail
  };
}

function mergeHookLists(existingList, incomingList) {
  const out = Array.isArray(existingList) ? [...existingList] : [];
  const seen = new Set(out.map((item) => JSON.stringify(item)));

  for (const item of incomingList || []) {
    const key = JSON.stringify(item);
    if (seen.has(key)) continue;
    out.push(item);
    seen.add(key);
  }

  return out;
}

function mergeSettingsHooks(settings, incoming) {
  const next = {
    ...settings,
    hooks: {
      ...(settings.hooks || {})
    }
  };

  for (const [hookName, hookList] of Object.entries(incoming.hooks || {})) {
    next.hooks[hookName] = mergeHookLists(next.hooks[hookName], hookList);
  }

  return next;
}

function redactSettingsForPrint(value) {
  const cloned = JSON.parse(JSON.stringify(value || {}));
  const env = cloned.env || {};

  for (const key of Object.keys(env)) {
    if (/(TOKEN|KEY|SECRET|PASSWORD|AUTH|CREDENTIAL)/i.test(key)) {
      env[key] = '[redacted]';
    }
  }

  return cloned;
}

function installHooks({ scope, settingsPath, dryRun }) {
  const pluginRoot = path.resolve(__dirname, '..');
  const targetPath = getSettingsPath(scope, settingsPath);
  const incoming = buildHooksObject(pluginRoot);

  let existing = {};
  if (fs.existsSync(targetPath)) {
    existing = JSON.parse(fs.readFileSync(targetPath, 'utf8'));
  }

  const merged = mergeSettingsHooks(existing, incoming);

  console.log('ACC-INSTALL-HOOKS/0.1');
  console.log(`scope: ${scope || 'custom'}`);
  console.log(`settings: ${targetPath}`);
  console.log(`dry_run: ${dryRun ? 'yes' : 'no'}`);

  if (dryRun) {
    console.log('');
    console.log(JSON.stringify(redactSettingsForPrint(merged), null, 2));
    return;
  }

  fs.mkdirSync(path.dirname(targetPath), { recursive: true });

  if (fs.existsSync(targetPath)) {
    const backupPath = `${targetPath}.bak-${new Date().toISOString().replace(/[:.]/g, '-')}`;
    fs.copyFileSync(targetPath, backupPath);
    console.log(`backup: ${backupPath}`);
  }

  fs.writeFileSync(targetPath, `${JSON.stringify(merged, null, 2)}\n`, 'utf8');
  console.log('installed: yes');
  console.log(scope === 'user'
    ? 'restart Claude Code to load the global hooks'
    : 'restart Claude Code from this project directory to load the hooks');
}

function removeAccHooks(settings) {
  const next = {
    ...settings,
    hooks: {
      ...(settings.hooks || {})
    }
  };

  let removed = 0;
  for (const [hookName, hookList] of Object.entries(next.hooks)) {
    if (!Array.isArray(hookList)) continue;
    const kept = hookList.filter((entry) => {
      const shouldRemove = isAccHookEntry(entry);
      if (shouldRemove) removed += 1;
      return !shouldRemove;
    });

    if (kept.length) {
      next.hooks[hookName] = kept;
    } else {
      delete next.hooks[hookName];
    }
  }

  return { settings: next, removed };
}

function uninstallHooks({ scope, settingsPath, dryRun }) {
  const targetPath = getSettingsPath(scope, settingsPath);
  console.log('ACC-UNINSTALL-HOOKS/0.1');
  console.log(`scope: ${scope || 'custom'}`);
  console.log(`settings: ${targetPath}`);
  console.log(`dry_run: ${dryRun ? 'yes' : 'no'}`);

  if (!fs.existsSync(targetPath)) {
    console.log('installed: no');
    console.log('removed: 0');
    return;
  }

  const existing = JSON.parse(fs.readFileSync(targetPath, 'utf8'));
  const result = removeAccHooks(existing);
  console.log(`removed: ${result.removed}`);

  if (dryRun) {
    console.log('');
    console.log(JSON.stringify(redactSettingsForPrint(result.settings), null, 2));
    return;
  }

  const backupPath = `${targetPath}.bak-${new Date().toISOString().replace(/[:.]/g, '-')}`;
  fs.copyFileSync(targetPath, backupPath);
  fs.writeFileSync(targetPath, `${JSON.stringify(result.settings, null, 2)}\n`, 'utf8');
  console.log(`backup: ${backupPath}`);
  console.log('uninstalled: yes');
  console.log('restart Claude Code to apply the change');
}

function printStatus({ scope, settingsPath }) {
  const targetPath = getSettingsPath(scope, settingsPath);
  console.log('ACC-STATUS/0.1');
  console.log(`scope: ${scope || 'custom'}`);
  console.log(`settings: ${targetPath}`);
  console.log(`settings_exists: ${fs.existsSync(targetPath) ? 'yes' : 'no'}`);

  if (!fs.existsSync(targetPath)) {
    console.log('installed: no');
    return;
  }

  const settings = JSON.parse(fs.readFileSync(targetPath, 'utf8'));
  const status = getHookInstallStatus(settings);
  console.log(`installed: ${status.installed ? 'yes' : 'no'}`);
  for (const [hookName, installed] of Object.entries(status.detail)) {
    console.log(`${hookName}: ${installed ? 'yes' : 'no'}`);
  }
}

function cleanArtifacts({ dataDir, keep, olderThan, dryRun }) {
  const artifacts = listArtifacts(dataDir);
  const olderThanMs = parseDurationMs(olderThan);
  const cutoff = olderThanMs == null ? null : Date.now() - olderThanMs;
  const toDelete = [];

  for (let i = 0; i < artifacts.length; i++) {
    const artifact = artifacts[i];
    const removeByKeep = keep != null && i >= keep;
    const created = Date.parse(artifact.created_at || '');
    const removeByAge = cutoff != null && Number.isFinite(created) && created < cutoff;

    if (removeByKeep || removeByAge) {
      toDelete.push({
        artifact,
        reason: removeByKeep && removeByAge ? 'keep+age' : (removeByKeep ? 'keep' : 'age')
      });
    }
  }

  console.log('ACC-CLEAN/0.1');
  console.log(`data_dir: ${dataDir}`);
  console.log(`artifacts: ${artifacts.length}`);
  console.log(`delete: ${toDelete.length}`);
  console.log(`dry_run: ${dryRun ? 'yes' : 'no'}`);

  if (!toDelete.length) return;

  const artifactRoot = path.join(path.resolve(dataDir), 'artifacts');
  for (const item of toDelete) {
    const artifactId = item.artifact.artifact_id;
    console.log(`${dryRun ? 'would delete' : 'deleted'} ${artifactId} (${item.reason})`);
    if (!dryRun) {
      fs.rmSync(path.join(artifactRoot, artifactId), { recursive: true, force: true });
    }
  }
}

function commandContainsShellSyntax(parts) {
  return parts.some((item) => ['&&', '||', ';', '|', '>', '<', '|&'].includes(item));
}

function normalizeCommandArgs(commandParts) {
  const [command, ...rest] = commandParts;
  if (!command) {
    return { command, args: [], useShell: false, shellCommand: '' };
  }

  // Special-case node -e / node -p style where script may include spaces that shell originally preserved.
  const mergedRest = [...rest];
  if ((command === 'node' || command === 'python' || command === 'python3') && mergedRest.length > 1 && mergedRest[0] === '-e') {
    mergedRest[1] = mergedRest.slice(1).join(' ');
    while (mergedRest.length > 2) {
      mergedRest.pop();
    }
  }

  if (commandContainsShellSyntax(mergedRest)) {
    return {
      command,
      args: mergedRest,
      useShell: true,
      shellCommand: `${command} ${mergedRest.join(' ')}`
    };
  }

  return { command, args: mergedRest, useShell: false, shellCommand: '' };
}

async function runCommand(parsed) {
  const { command, args, useShell, shellCommand } = parsed;
  return new Promise((resolve) => {
    const child = spawn(
      useShell ? shellCommand : command,
      useShell ? [] : args,
      {
      shell: useShell,
      stdio: ['ignore', 'pipe', 'pipe'],
      windowsHide: true
    });

    let stdout = '';
    let stderr = '';

    child.stdout.on('data', (chunk) => {
      stdout += chunk.toString();
    });

    child.stderr.on('data', (chunk) => {
      stderr += chunk.toString();
    });

    child.on('error', (err) => {
      stderr += `\n[acc-run:spawn-error] ${err.message}`;
    });

    child.on('close', (code) => {
      resolve({ code, stdout, stderr, interrupted: false, isImage: false });
    });
  });
}

function showArtifact(artifactId, dataDir) {
  const resolvedArtifactId = resolveArtifactId(artifactId, dataDir);
  const artifact = readArtifact(dataDir, resolvedArtifactId);
  if (!artifact) {
    console.error(`artifact not found: ${resolvedArtifactId}`);
    process.exit(1);
  }

  process.stdout.write(`artifact_id: ${artifact.meta.artifact_id}\n`);
  process.stdout.write(`created_at: ${artifact.meta.created_at}\n`);
  process.stdout.write(`command: ${artifact.meta.command}\n`);
  process.stdout.write(`status: ${artifact.meta.status}\n`);
  process.stdout.write(`cwd: ${artifact.meta.cwd}\n`);
  process.stdout.write('--- RAW STDOUT ---\n');
  process.stdout.write(artifact.stdout);
  if (artifact.stdout && !artifact.stdout.endsWith('\n')) process.stdout.write('\n');
  process.stdout.write('--- RAW STDERR ---\n');
  process.stdout.write(artifact.stderr);
  if (artifact.stderr && !artifact.stderr.endsWith('\n')) process.stdout.write('\n');
}

function expandArtifact(artifactId, keyword, dataDir) {
  const resolvedArtifactId = resolveArtifactId(artifactId, dataDir);
  const artifact = readArtifact(dataDir, resolvedArtifactId);
  if (!artifact) {
    console.error(`artifact not found: ${resolvedArtifactId}`);
    process.exit(1);
  }

  if (!keyword) {
    console.error('missing --around keyword');
    process.exit(1);
  }

  const expanded = expandArtifactAround(artifact, keyword);
  process.stdout.write(expanded || 'No matching lines\n');
}

async function main() {
  const args = process.argv.slice(2);

  if (args[0] === '--help' || args[0] === '-h') {
    usage();
    process.exit(0);
  }

  if (args.length === 0) {
    usage();
    process.exit(1);
  }

  const command = args[0];

  if (command === 'run') {
    const rest = args.slice(1);
    const { agent, dataDir, commandParts, encodedCommand } = parseRunArgs(rest);

    if (!encodedCommand && commandParts.length === 0) {
      console.error('acc run missing command after --');
      usage();
      process.exit(1);
    }

    const commandText = encodedCommand || commandParts.join(' ');
    const commandForRun = encodedCommand
      ? { command: process.env.SHELL || '/bin/sh', args: ['-lc', encodedCommand], useShell: false, shellCommand: '' }
      : normalizeCommandArgs(commandParts);
    const result = await runCommand(commandForRun);
    const beforeText = `${result.stdout}\n${result.stderr}`;
    const outputReducer = getReducerForOutput({
      command: commandText,
      stdout: result.stdout,
      stderr: result.stderr
    });

    if (agent && !isNoisyCommand(commandText) && outputReducer === 'bash_generic' && estimateTokens(beforeText) < 8000) {
      if (result.stdout) process.stdout.write(result.stdout);
      if (result.stderr) process.stderr.write(result.stderr);
      process.exit(0);
    }

    const reducer = getReducerForOutput({
      command: commandText,
      stdout: result.stdout,
      stderr: result.stderr
    }) || (isNoisyCommand(commandText) ? 'bash_generic' : getReducerForCommand(commandText));

    const compacted = compactOutput({
      tool: 'Bash',
      command: commandText,
      exitCode: result.code,
      stdout: result.stdout,
      stderr: result.stderr,
      reducer,
      dataDir,
      beforeText: `${result.stdout}\n${result.stderr}`,
      fromPost: false
    });

    const artifact = createArtifact({
      dataDir,
      command: commandText,
      exitCode: result.code,
      reducer,
      stdout: result.stdout,
      stderr: result.stderr,
      compactedText: compacted.text,
      beforeTokens: compacted.beforeTokens,
      afterTokens: compacted.afterTokens,
      status: compacted.status
    });

    const outputText = compacted.text.replace(
      'acc show null',
      formatArtifactPointer(artifact.artifact_id, {
        accPath: __filename,
        dataDir
      })
    );

    console.log(outputText);
    if (agent) {
      process.exit(0);
    }
    process.exit(result.code || 0);
    return;
  }

  if (command === 'compact') {
    const parsed = parseCompactArgs(args.slice(1));
    if (!parsed.stdin) {
      console.error('acc compact requires --stdin');
      process.exit(1);
    }

    const inputText = fs.readFileSync(0, 'utf8');
    const reducer = parsed.reducer || getReducerForOutput({
      command: parsed.commandLabel,
      stdout: inputText,
      stderr: ''
    });

    const compacted = compactOutput({
      tool: 'stdin',
      command: parsed.commandLabel,
      exitCode: parsed.exitCode,
      stdout: inputText,
      stderr: '',
      reducer,
      dataDir: parsed.dataDir,
      beforeText: inputText
    });

    const artifact = createArtifact({
      dataDir: parsed.dataDir,
      command: parsed.commandLabel,
      exitCode: parsed.exitCode,
      reducer,
      stdout: inputText,
      stderr: '',
      compactedText: compacted.text,
      beforeTokens: compacted.beforeTokens,
      afterTokens: compacted.afterTokens,
      status: compacted.status
    });

    console.log(compacted.text.replace(
      'acc show null',
      formatArtifactPointer(artifact.artifact_id, {
        accPath: __filename,
        dataDir: parsed.dataDir
      })
    ));
    process.exit(0);
  }

  if (command === 'list') {
    const parsed = parseListArgs(args.slice(1));
    const artifacts = listArtifacts(parsed.dataDir).slice(0, parsed.limit);

    console.log('ACC-ARTIFACTS/0.1');
    console.log(`data_dir: ${parsed.dataDir}`);
    console.log(`count: ${artifacts.length}`);
    console.log('');

    if (!artifacts.length) {
      console.log('(no artifacts found)');
      process.exit(0);
    }

    artifacts.forEach((meta, index) => printArtifactSummary(meta, index));
    process.exit(0);
  }

  if (command === 'latest') {
    const parsed = parseDoctorArgs(args.slice(1));
    const latest = listArtifacts(parsed.dataDir)[0];
    if (!latest) {
      console.error(`no artifacts found in ${parsed.dataDir}`);
      process.exit(1);
    }

    console.log('ACC-LATEST/0.1');
    printArtifactSummary(latest, null);
    console.log(`show: ${formatArtifactPointer(latest.artifact_id, { accPath: __filename, dataDir: parsed.dataDir })}`);
    console.log(`expand: node '${__filename.replace(/'/g, "'\\''")}' expand ${latest.artifact_id} --around "<keyword>" --data-dir '${String(parsed.dataDir).replace(/'/g, "'\\''")}'`);
    process.exit(0);
  }

  if (command === 'print-hooks') {
    const parsed = parseDoctorArgs(args.slice(1));
    printHooks(parsed.dataDir);
    process.exit(0);
  }

  if (command === 'status') {
    const parsed = parseSettingsScopeArgs(args.slice(1));
    if (!['user', 'project'].includes(parsed.scope) && !parsed.settingsPath) {
      console.error('acc status requires --user, --project, or --settings <path>');
      process.exit(1);
    }
    printStatus(parsed);
    process.exit(0);
  }

  if (command === 'install-hooks') {
    const parsed = parseInstallHooksArgs(args.slice(1));
    if (!['user', 'project'].includes(parsed.scope) && !parsed.settingsPath) {
      console.error('acc install-hooks requires --user, --project, or --settings <path>');
      process.exit(1);
    }
    installHooks(parsed);
    process.exit(0);
  }

  if (command === 'uninstall-hooks') {
    const parsed = parseSettingsScopeArgs(args.slice(1));
    if (!['user', 'project'].includes(parsed.scope) && !parsed.settingsPath) {
      console.error('acc uninstall-hooks requires --user, --project, or --settings <path>');
      process.exit(1);
    }
    uninstallHooks(parsed);
    process.exit(0);
  }

  if (command === 'clean') {
    const parsed = parseCleanArgs(args.slice(1));
    cleanArtifacts(parsed);
    process.exit(0);
  }

  if (command === 'doctor') {
    const parsed = parseDoctorArgs(args.slice(1));
    runDoctor(parsed.dataDir);
    process.exit(0);
  }

  if (command === 'show') {
    const parsed = parseShowOrExpandArgs(args.slice(1));
    const artifactId = parsed.positional[0];
    if (!artifactId) {
      console.error('acc show missing artifact_id');
      process.exit(1);
    }
    showArtifact(artifactId, parsed.dataDir);
    process.exit(0);
  }

  if (command === 'expand') {
    const parsed = parseShowOrExpandArgs(args.slice(1));
    const artifactId = parsed.positional[0];
    if (!artifactId) {
      console.error('acc expand missing artifact_id');
      process.exit(1);
    }
    expandArtifact(artifactId, parsed.around, parsed.dataDir);
    process.exit(0);
  }

  usage();
  process.exit(1);
}

main().catch((err) => {
  console.error(err && err.message ? err.message : String(err));
  process.exit(1);
});
