  console.log('  tokenless expand <artifact_id|latest> --around <keyword> --data-dir <dir>');
  console.log('  tokenless clean --data-dir <dir> [--keep <n>] [--older-than <7d|24h|60m>] [--dry-run]');
}

function stripQuotes(value) {
  if (typeof value !== 'string') {
    return value;
  }

  const startsSingle = value.startsWith("'") && value.endsWith("'");
  const startsDouble = value.startsWith('"') && value.endsWith('"');
  if (value.length >= 2 && (startsSingle || startsDouble)) {
    return value.slice(1, -1);
  }
  return value;
}

function shellQuote(value) {
  return `'${String(value).replace(/'/g, "'\\''")}'`;
}

function timestampSlug(date = new Date()) {
  return date.toISOString().replace(/[-:T.Z]/g, '').slice(0, 14);
}

function sanitizeSlug(value) {
  return String(value || 'run')
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9._-]+/g, '-')
    .replace(/^-+|-+$/g, '') || 'run';
}

const TASK_PLAN_TOOLS = [
  'TaskCreate',
  'TaskUpdate',
  'TaskList',
  'TaskGet',
  'EnterPlanMode',
  'ExitPlanMode'
];

function parseLaunchArgs(args) {
  const parsed = {
    claudeBin: process.env.CLAUDE_BIN || 'claude',
    allowTaskTools: process.env.TOKENLESS_ALLOW_TASK_TOOLS === '1',
    print: false,
    claudeArgs: []
  };

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    if (arg === '--') {
      parsed.claudeArgs.push(...args.slice(i + 1));
      break;
    }
    if (arg === '--claude-bin') {
      parsed.claudeBin = args[++i];
      continue;
    }
    if (arg === '--allow-task-tools') {
      parsed.allowTaskTools = true;
      continue;
    }
    if (arg === '--print' || arg === '--dry-run') {
      parsed.print = true;
      continue;
    }
    parsed.claudeArgs.push(arg);
  }

  if (!parsed.claudeBin) {
    parsed.claudeBin = 'claude';
  }
  return parsed;
}

function buildLaunchCommand(parsed) {
  const command = [parsed.claudeBin, ...parsed.claudeArgs];
  if (!parsed.allowTaskTools) {
    command.push('--disallowedTools', TASK_PLAN_TOOLS.join(','));
  }
  return command;
}

function printLaunch(parsed, command) {
  console.log('TOKENLESS-LAUNCH/0.1');
  console.log(`claude_bin: ${parsed.claudeBin}`);
  console.log(`task_plan_tools: ${parsed.allowTaskTools ? 'allowed' : 'disabled'}`);
  console.log(`command: ${command.map(shellQuote).join(' ')}`);
}

function launchClaude(args) {
  const parsed = parseLaunchArgs(args);
  const command = buildLaunchCommand(parsed);
  if (parsed.print) {
    printLaunch(parsed, command);
    return;
  }

  const child = spawn(command[0], command.slice(1), {
    stdio: 'inherit',
    env: process.env
  });
  child.on('exit', (code, signal) => {
    if (signal) {
      process.kill(process.pid, signal);
      return;
    }
    process.exit(code == null ? 1 : code);
  });
  child.on('error', (err) => {
    console.error(`tokenless launch failed: ${err.message}`);
    process.exit(1);
  });
}

function parseShowOrExpandArgs(args) {
  let around;
  let lines;
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.tokenless');
  const positional = [];

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    if (arg === '--data-dir') {
      dataDir = stripQuotes(args[i + 1]);
      i += 1;
      continue;
    }
    if (arg === '--around') {
      around = args[i + 1];
      i += 1;
      continue;
    }
    if (arg === '--lines') {
      lines = args[i + 1];
      i += 1;
      continue;
    }
    if (arg === '--') {
      continue;
    }
    positional.push(arg);
  }

  return { dataDir, around, lines, positional };
}

function parseRunArgs(argv) {
  let i = 0;
  let agent = false;
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.tokenless');
  let encodedCommand = null;

  while (i < argv.length) {
    const arg = argv[i];
    if (arg === '--agent') {
      agent = true;
      i += 1;
      continue;
    }
    if (arg === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 2;
      continue;
    }
    if (arg === '--cmd-b64') {
      encodedCommand = Buffer.from(String(argv[i + 1] || ''), 'base64').toString('utf8');
      i += 2;
      continue;
    }
    if (arg === '--') {
      i += 1;
      break;
    }
    i += 1;
  }

  const commandParts = argv.slice(i);
  return { agent, dataDir, commandParts, encodedCommand };
}

function parseCompactArgs(argv) {
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.tokenless');
  let reducer = null;
  let stdin = false;
  let commandLabel = 'stdin';
  let exitCode = 0;

  for (let i = 0; i < argv.length; i++) {
    const arg = argv[i];
    if (arg === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (arg === '--type') {
      reducer = argv[i + 1];
      i += 1;
      continue;
    }
    if (arg === '--stdin') {
      stdin = true;
      continue;
    }
    if (arg === '--command') {
      commandLabel = argv[i + 1];
      i += 1;
      continue;
    }
    if (arg === '--exit-code') {
      exitCode = Number(argv[i + 1]) || 0;
      i += 1;
      continue;
    }
  }

  return { dataDir, reducer, stdin, commandLabel, exitCode };
}

function parseReadArgs(argv) {
  let agent = false;
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.tokenless');
  const positional = [];

  for (let i = 0; i < argv.length; i++) {
    const arg = argv[i];
    if (arg === '--agent') {
      agent = true;
      continue;
    }
    if (arg === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (arg === '--') {
      continue;
    }
    positional.push(arg);
  }

  return { agent, dataDir, filePath: stripQuotes(positional[0] || '') };
}

function parseDoctorArgs(argv) {
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.tokenless');
  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
    }
  }
  return { dataDir };
}

function parseListArgs(argv) {
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.tokenless');
  let limit = 20;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--limit') {
      limit = Math.max(1, Number(argv[i + 1]) || limit);
      i += 1;
    }
  }

  return { dataDir, limit };
}

function parseCleanArgs(argv) {
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.tokenless');
  let keep = null;
  let olderThan = null;
  let dryRun = false;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--keep') {
      keep = Math.max(0, Number(argv[i + 1]) || 0);
      i += 1;
      continue;
    }
    if (argv[i] === '--older-than') {
      olderThan = String(argv[i + 1] || '');
      i += 1;
      continue;
    }
    if (argv[i] === '--dry-run') {
      dryRun = true;
    }
  }

  return { dataDir, keep, olderThan, dryRun };
}

function parseSlashCommandArgs(argv) {
  let scope = 'user';
  let dryRun = false;
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.tokenless');
  let commandsDir = null;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--user') {
      scope = 'user';
      continue;
    }
    if (argv[i] === '--dry-run') {
      dryRun = true;
      continue;
    }
    if (argv[i] === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--commands-dir') {
      commandsDir = stripQuotes(argv[i + 1]);
      i += 1;
    }
  }

  return { scope, dryRun, dataDir, commandsDir };
}

function parseApiUsageArgs(argv) {
  let source = path.join(os.homedir(), '.claude', 'projects');
  let since = null;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--source') {
      source = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--since') {
      since = String(argv[i + 1] || '');
      i += 1;
    }
  }

  return { source, since };
}

function parseApiProbeArgs(argv) {
  const action = argv[0] || 'help';
  let dir = path.join(os.homedir(), '.tokenless', 'api-bodies');
  let dataDir = process.env.CLAUDE_PLUGIN_DATA || path.join(os.homedir(), '.tokenless');
  let keyword = null;
  let showSnippet = false;
  let name = null;

  for (let i = 1; i < argv.length; i++) {
    if (argv[i] === '--dir') {
      dir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--name') {
      name = String(stripQuotes(argv[i + 1]) || '').trim();
      i += 1;
      continue;
    }
    if (argv[i] === '--data-dir') {
      dataDir = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--keyword') {
      keyword = argv[i + 1];
      i += 1;
      continue;
    }
    if (argv[i] === '--show-snippet') {
      showSnippet = true;
    }
  }

  if (name && !argv.includes('--dir')) {
    dir = path.join(os.homedir(), '.tokenless', `api-bodies-${sanitizeSlug(name)}-${timestampSlug()}`);
  }

  return { action, dir, dataDir, keyword, showSnippet, name };
}

function parseBenchmarkCopyArgs(argv) {
  const fixture = argv[0] || '';
  let source = null;
  let outRoot = os.homedir();
  let name = null;
  let file = null;

  for (let i = 1; i < argv.length; i++) {
    if (argv[i] === '--source') {
      source = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--out-root') {
      outRoot = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--name') {
      name = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--file') {
      file = stripQuotes(argv[i + 1]);
      i += 1;
    }
  }

  return { fixture, source, outRoot, name, file };
}

function parseInstallHooksArgs(argv) {
  let scope = null;
  let settingsPath = null;
  let dryRun = false;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--project') {
      scope = 'project';
      continue;
    }
    if (argv[i] === '--user') {
      scope = 'user';
      continue;
    }
    if (argv[i] === '--settings') {
      settingsPath = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--dry-run') {
      dryRun = true;
    }
  }

  return { scope, settingsPath, dryRun };
}

function parseSettingsScopeArgs(argv) {
  let scope = null;
  let settingsPath = null;
  let dryRun = false;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--user') {
      scope = 'user';
      continue;
    }
    if (argv[i] === '--project') {
      scope = 'project';
      continue;
    }
    if (argv[i] === '--settings') {
      settingsPath = stripQuotes(argv[i + 1]);
      i += 1;
      continue;
    }
    if (argv[i] === '--dry-run') {
      dryRun = true;
    }
  }

  return { scope, settingsPath, dryRun };
}

function okLine(label, value) {
  console.log(`[ok] ${label}: ${value}`);
}

function failLine(label, value) {
  console.log(`[fail] ${label}: ${value}`);
}

function checkReadableJson(label, filePath) {
  try {
    JSON.parse(fs.readFileSync(filePath, 'utf8'));
    okLine(label, filePath);
    return true;
  } catch (err) {
    failLine(label, `${filePath} (${err.message})`);
    return false;
  }
}

function runDoctor(dataDir) {
  const pluginRoot = path.resolve(__dirname, '..');
  const hooksPath = path.join(pluginRoot, 'hooks', 'hooks.json');
  const manifestPath = path.join(pluginRoot, '.claude-plugin', 'plugin.json');
  const preToolPath = path.join(pluginRoot, 'scripts', 'pre_tool_use.js');
  const postToolPath = path.join(pluginRoot, 'scripts', 'post_tool_use.js');
  const postToolFailurePath = path.join(pluginRoot, 'scripts', 'post_tool_failure.js');
  const postToolProbePath = path.join(pluginRoot, 'scripts', 'post_tool_probe.js');
  const userSettingsPath = path.join(os.homedir(), '.claude', 'settings.json');

  console.log('TOKENLESS-DOCTOR/0.1');
  console.log('');
  okLine('node', process.version);
  okLine('tokenless cli', __filename);
  okLine('plugin root', pluginRoot);
  okLine('CLAUDE_PLUGIN_ROOT', process.env.CLAUDE_PLUGIN_ROOT || '(not set)');
  okLine('CLAUDE_PLUGIN_DATA', process.env.CLAUDE_PLUGIN_DATA || '(not set)');

  checkReadableJson('plugin manifest', manifestPath);
  checkReadableJson('hooks json', hooksPath);

  for (const filePath of [preToolPath, postToolPath, postToolFailurePath, postToolProbePath]) {
    if (fs.existsSync(filePath)) okLine('script exists', filePath);
    else failLine('script exists', filePath);
  }

  try {
    fs.mkdirSync(dataDir, { recursive: true });
    const testPath = path.join(dataDir, '.tokenless-doctor-write-test');
    fs.writeFileSync(testPath, 'ok\n', 'utf8');
    fs.unlinkSync(testPath);
    okLine('data dir writable', dataDir);
  } catch (err) {
    failLine('data dir writable', `${dataDir} (${err.message})`);
  }

  const sampleCommand = Buffer.from('npm run build', 'utf8').toString('base64');
  const sampleRewrite = `node '${__filename.replace(/'/g, "'\\''")}' run --agent --data-dir '${dataDir.replace(/'/g, "'\\''")}' --cmd-b64 '${sampleCommand}'`;
  okLine('sample PreToolUse rewrite', sampleRewrite);

  if (fs.existsSync(userSettingsPath)) {
    try {
      const userSettings = JSON.parse(fs.readFileSync(userSettingsPath, 'utf8'));
      const status = getHookInstallStatus(userSettings);
      okLine('user settings readable', userSettingsPath);
      okLine('user hooks installed', status.installed ? 'yes' : 'no');
    } catch (err) {
      failLine('user settings readable', `${userSettingsPath} (${err.message})`);
    }
  } else {
    failLine('user settings readable', `${userSettingsPath} (not found)`);
  }

  const stale = [];
  for (const settingsPath of candidateSettingsPaths()) {
    if (!fs.existsSync(settingsPath)) continue;
    try {
      const settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8'));
      stale.push(...findStaleTokenlessHooks(settings, settingsPath, pluginRoot));
    } catch (err) {
      failLine('stale hook scan', `${settingsPath} (${err.message})`);
    }
  }

  if (!stale.length) {
    okLine('stale Tokenless/ACC hooks', 'none');
  } else {
    for (const item of stale) {
      failLine('stale Tokenless/ACC hook', `${item.settings} ${item.hook}:${item.matcher}`);
    }
    console.log('repair: tokenless repair-hooks --user --project');
  }
}

function resolveArtifactId(artifactId, dataDir) {
  if (artifactId !== 'latest') {
    return artifactId;
  }

  const latest = listArtifacts(dataDir)[0];
  if (!latest) {
    console.error(`no artifacts found in ${dataDir}`);
    process.exit(1);
  }

  return latest.artifact_id;
}

function printArtifactSummary(meta, index) {
  const prefix = index == null ? '' : `${String(index + 1).padStart(2, '0')}. `;
  process.stdout.write(`${prefix}${meta.artifact_id}  ${meta.status || 'unknown'}  ${meta.reducer || 'unknown'}  ${meta.created_at || 'unknown'}\n`);
  process.stdout.write(`    command: ${String(meta.command || '').slice(0, 180)}\n`);
}

function parseDurationMs(value) {
  if (!value) return null;
  const match = /^(\d+)(m|h|d)$/i.exec(String(value).trim());
  if (!match) {
    throw new Error(`invalid duration: ${value}. Use forms like 60m, 24h, or 7d.`);
  }

  const amount = Number(match[1]);
  const unit = match[2].toLowerCase();
  if (unit === 'm') return amount * 60 * 1000;
  if (unit === 'h') return amount * 60 * 60 * 1000;
  return amount * 24 * 60 * 60 * 1000;
}

function printHooks(dataDir) {
  const pluginRoot = path.resolve(__dirname, '..');
  const hooks = buildHooksObject(pluginRoot);

  console.log('TOKENLESS-HOOKS/0.1');
  console.log(`data_dir: ${dataDir}`);
  console.log('');
  console.log(JSON.stringify(hooks, null, 2));
}

function buildHooksObject(pluginRoot) {
  return {
    hooks: {
      PreToolUse: [
        {
          matcher: 'Bash',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'pre_tool_use.js')}"`
            }
          ]
        },
        {
          matcher: 'Read',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'pre_tool_use.js')}"`
            }
          ]
        },
        {
          matcher: 'Edit',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'pre_tool_use.js')}"`
            }
          ]
        },
        {
          matcher: 'MultiEdit',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'pre_tool_use.js')}"`
            }
          ]
        },
        {
          matcher: 'Write',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'pre_tool_use.js')}"`
            }
          ]
        }
      ],
      PostToolUse: [
        {
          matcher: '*',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'post_tool_use.js')}"`
            }
          ]
        },
        {
          matcher: 'Edit',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'post_tool_probe.js')}"`
            }
          ]
        },
        {
          matcher: 'MultiEdit',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'post_tool_probe.js')}"`
            }
          ]
        },
        {
          matcher: 'Write',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'post_tool_probe.js')}"`
            }
          ]
        }
      ],
      PostToolUseFailure: [
        {
          matcher: 'Bash',
          hooks: [
            {
              type: 'command',
              command: `node "${path.join(pluginRoot, 'scripts', 'post_tool_failure.js')}"`
            }
          ]
        }
      ]
    }
  };
}

function getSettingsPath(scope, settingsPath) {
  if (settingsPath) return settingsPath;
  if (scope === 'user') return path.join(os.homedir(), '.claude', 'settings.json');
  if (scope === 'project') return path.join(process.cwd(), '.claude', 'settings.local.json');
  return null;
}

function isTokenlessHookEntry(entry) {
  const text = JSON.stringify(entry || {}).replace(/\\/g, '/');
  return text.includes('/plugins/claude-code/scripts/pre_tool_use.js') ||
    text.includes('/plugins/claude-code/scripts/post_tool_use.js') ||
    text.includes('/plugins/claude-code/scripts/post_tool_failure.js') ||
    text.includes('/plugins/claude-code/scripts/post_tool_probe.js');
}

function normalizePathForCompare(value) {
  return path.resolve(String(value || '')).replace(/\\/g, '/');
}

function isStaleTokenlessHookEntry(entry, pluginRoot) {
  const text = JSON.stringify(entry || {}).replace(/\\/g, '/');
  if (!isTokenlessHookEntry(entry)) return false;
  return !text.includes(normalizePathForCompare(pluginRoot));
}

function findStaleTokenlessHooks(settings, settingsPath, pluginRoot) {
  const hooks = settings.hooks || {};
  const stale = [];

  for (const [hookName, hookList] of Object.entries(hooks)) {
    if (!Array.isArray(hookList)) continue;
    for (const entry of hookList) {
      if (!isStaleTokenlessHookEntry(entry, pluginRoot)) continue;
      stale.push({
        settings: settingsPath,
        hook: hookName,
        matcher: entry && entry.matcher ? entry.matcher : '(none)',
        command: JSON.stringify(entry)
      });
    }
  }

  return stale;
}

function removeStaleTokenlessHooks(settings, pluginRoot) {
  const next = {
    ...settings,
    hooks: {
      ...(settings.hooks || {})
    }
  };

  let removed = 0;
  for (const [hookName, hookList] of Object.entries(next.hooks)) {
    if (!Array.isArray(hookList)) continue;
    const kept = hookList.filter((entry) => {
      const stale = isStaleTokenlessHookEntry(entry, pluginRoot);
      if (stale) removed += 1;
      return !stale;
    });

    if (kept.length) next.hooks[hookName] = kept;
    else delete next.hooks[hookName];
  }

  return { settings: next, removed };
}

function candidateSettingsPaths() {
  const paths = [
    path.join(os.homedir(), '.claude', 'settings.json'),
    path.join(process.cwd(), '.claude', 'settings.json'),
    path.join(process.cwd(), '.claude', 'settings.local.json')
  ];
  return [...new Set(paths)];
}

function getHookInstallStatus(settings) {
  const hooks = settings.hooks || {};
  const postToolUse = Array.isArray(hooks.PostToolUse) ? hooks.PostToolUse : [];
  const detail = {
    'PreToolUse:Bash': (Array.isArray(hooks.PreToolUse) ? hooks.PreToolUse : []).some((entry) => entry && entry.matcher === 'Bash' && isTokenlessHookEntry(entry)),
    'PreToolUse:Read': (Array.isArray(hooks.PreToolUse) ? hooks.PreToolUse : []).some((entry) => entry && entry.matcher === 'Read' && isTokenlessHookEntry(entry)),
    'PreToolUse:Edit': (Array.isArray(hooks.PreToolUse) ? hooks.PreToolUse : []).some((entry) => entry && entry.matcher === 'Edit' && isTokenlessHookEntry(entry)),
    'PreToolUse:MultiEdit': (Array.isArray(hooks.PreToolUse) ? hooks.PreToolUse : []).some((entry) => entry && entry.matcher === 'MultiEdit' && isTokenlessHookEntry(entry)),
    'PreToolUse:Write': (Array.isArray(hooks.PreToolUse) ? hooks.PreToolUse : []).some((entry) => entry && entry.matcher === 'Write' && isTokenlessHookEntry(entry)),
    'PostToolUse:*': postToolUse.some((entry) => entry && entry.matcher === '*' && isTokenlessHookEntry(entry)),
    'PostToolUse:Edit': postToolUse.some((entry) => entry && entry.matcher === 'Edit' && isTokenlessHookEntry(entry)),
    'PostToolUse:MultiEdit': postToolUse.some((entry) => entry && entry.matcher === 'MultiEdit' && isTokenlessHookEntry(entry)),
    'PostToolUse:Write': postToolUse.some((entry) => entry && entry.matcher === 'Write' && isTokenlessHookEntry(entry)),
    PostToolUseFailure: (Array.isArray(hooks.PostToolUseFailure) ? hooks.PostToolUseFailure : []).some(isTokenlessHookEntry)
  };
  const expected = Object.keys(detail);

  return {
    installed: expected.every((hookName) => detail[hookName]),
    detail
  };
}

function mergeHookLists(existingList, incomingList) {
  const out = Array.isArray(existingList) ? [...existingList] : [];
  const seen = new Set(out.map((item) => JSON.stringify(item)));

  for (const item of incomingList || []) {
    const key = JSON.stringify(item);
    if (seen.has(key)) continue;
    out.push(item);
    seen.add(key);
  }

  return out;
}

function mergeSettingsHooks(settings, incoming) {
  const next = {
    ...settings,
    hooks: {
      ...(settings.hooks || {})
    }
  };

  for (const [hookName, hookList] of Object.entries(incoming.hooks || {})) {
    next.hooks[hookName] = mergeHookLists(next.hooks[hookName], hookList);
  }

  return next;
}

function redactSettingsForPrint(value) {
  const cloned = JSON.parse(JSON.stringify(value || {}));
  const env = cloned.env || {};

  for (const key of Object.keys(env)) {
    if (/(TOKEN|KEY|SECRET|PASSWORD|AUTH|CREDENTIAL)/i.test(key)) {
      env[key] = '[redacted]';
    }
  }

  return cloned;
}

function installHooks({ scope, settingsPath, dryRun }) {
  const pluginRoot = path.resolve(__dirname, '..');
  const targetPath = getSettingsPath(scope, settingsPath);
  const incoming = buildHooksObject(pluginRoot);

  let existing = {};
  if (fs.existsSync(targetPath)) {
    existing = JSON.parse(fs.readFileSync(targetPath, 'utf8'));
  }

  const merged = mergeSettingsHooks(existing, incoming);

  console.log('TOKENLESS-INSTALL-HOOKS/0.1');
  console.log(`scope: ${scope || 'custom'}`);
  console.log(`settings: ${targetPath}`);
  console.log(`dry_run: ${dryRun ? 'yes' : 'no'}`);

  if (dryRun) {
    console.log('');
    console.log(JSON.stringify(redactSettingsForPrint(merged), null, 2));
    return;
  }

  fs.mkdirSync(path.dirname(targetPath), { recursive: true });

  if (fs.existsSync(targetPath)) {
    const backupPath = `${targetPath}.bak-${new Date().toISOString().replace(/[:.]/g, '-')}`;
    fs.copyFileSync(targetPath, backupPath);
    console.log(`backup: ${backupPath}`);
  }

  fs.writeFileSync(targetPath, `${JSON.stringify(merged, null, 2)}\n`, 'utf8');
  console.log('installed: yes');
  console.log(scope === 'user'
    ? 'restart Claude Code to load the global hooks'
    : 'restart Claude Code from this project directory to load the hooks');
}

function removeTokenlessHooks(settings) {
  const next = {
    ...settings,
    hooks: {
      ...(settings.hooks || {})
    }
  };

  let removed = 0;
  for (const [hookName, hookList] of Object.entries(next.hooks)) {
    if (!Array.isArray(hookList)) continue;
    const kept = hookList.filter((entry) => {
      const shouldRemove = isTokenlessHookEntry(entry);
      if (shouldRemove) removed += 1;
      return !shouldRemove;
    });

    if (kept.length) {
      next.hooks[hookName] = kept;
    } else {
      delete next.hooks[hookName];
    }
  }

  return { settings: next, removed };
}

function uninstallHooks({ scope, settingsPath, dryRun }) {
  const targetPath = getSettingsPath(scope, settingsPath);
  console.log('TOKENLESS-UNINSTALL-HOOKS/0.1');
  console.log(`scope: ${scope || 'custom'}`);
  console.log(`settings: ${targetPath}`);
  console.log(`dry_run: ${dryRun ? 'yes' : 'no'}`);

  if (!fs.existsSync(targetPath)) {
    console.log('installed: no');
    console.log('removed: 0');
    return;
  }

  const existing = JSON.parse(fs.readFileSync(targetPath, 'utf8'));
  const result = removeTokenlessHooks(existing);
  console.log(`removed: ${result.removed}`);

  if (dryRun) {
    console.log('');
    console.log(JSON.stringify(redactSettingsForPrint(result.settings), null, 2));
    return;
  }

  const backupPath = `${targetPath}.bak-${new Date().toISOString().replace(/[:.]/g, '-')}`;
  fs.copyFileSync(targetPath, backupPath);
  fs.writeFileSync(targetPath, `${JSON.stringify(result.settings, null, 2)}\n`, 'utf8');
  console.log(`backup: ${backupPath}`);
  console.log('uninstalled: yes');
  console.log('restart Claude Code to apply the change');
}

function writeSettingsWithBackup(targetPath, settings, dryRun) {
  if (dryRun) {
    console.log(JSON.stringify(redactSettingsForPrint(settings), null, 2));
    return;
  }

  fs.mkdirSync(path.dirname(targetPath), { recursive: true });
  if (fs.existsSync(targetPath)) {
    const backupPath = `${targetPath}.bak-${new Date().toISOString().replace(/[:.]/g, '-')}`;
    fs.copyFileSync(targetPath, backupPath);
    console.log(`backup: ${backupPath}`);
  }
  fs.writeFileSync(targetPath, `${JSON.stringify(settings, null, 2)}\n`, 'utf8');
}

function repairHooks({ user, project, dryRun }) {
  const pluginRoot = path.resolve(__dirname, '..');
  const userPath = getSettingsPath('user');
  const projectPath = getSettingsPath('project');
  const targets = [];

  if (user) targets.push({ scope: 'user', path: userPath, installCurrent: true });
  if (project) targets.push({ scope: 'project', path: projectPath, installCurrent: false });
  if (!targets.length) targets.push({ scope: 'user', path: userPath, installCurrent: true });

  console.log('TOKENLESS-REPAIR-HOOKS/0.1');
  console.log(`dry_run: ${dryRun ? 'yes' : 'no'}`);

  for (const target of targets) {
    let existing = {};
    if (fs.existsSync(target.path)) {
      existing = JSON.parse(fs.readFileSync(target.path, 'utf8'));
    }

    const staleBefore = findStaleTokenlessHooks(existing, target.path, pluginRoot);
    let repaired = removeStaleTokenlessHooks(existing, pluginRoot).settings;
    const removed = staleBefore.length;

    if (target.installCurrent) {
      repaired = mergeSettingsHooks(repaired, buildHooksObject(pluginRoot));
    }

    console.log('');
    console.log(`scope: ${target.scope}`);
    console.log(`settings: ${target.path}`);
    console.log(`stale_removed: ${removed}`);
    console.log(`installed_current: ${target.installCurrent ? 'yes' : 'no'}`);

    writeSettingsWithBackup(target.path, repaired, dryRun);
  }

  console.log('');
  console.log('restart Claude Code to apply repaired hooks');
}

function getSlashCommandsDir(options = {}) {
  if (options.commandsDir) return options.commandsDir;
  return path.join(os.homedir(), '.claude', 'commands');
}

function buildSlashCommands({ cliPath, dataDir }) {
  const cli = shellQuote(cliPath);
  const dir = shellQuote(dataDir);

  return {
    'tokenless.md': [
      '---',
      'description: Show Tokenless status, savings, and latest artifact',
      'argument-hint: "[style <terse|caveman|reviewer|wenyan|off>]"',
      'allowed-tools: Bash',
      '---',
      '',
      'If the first argument is `style`, do not change settings yet. Explain briefly:',
      '',
      '```text',
      '/tokenless style is reserved for future output style profiles.',
      'Planned styles: terse, caveman, reviewer, wenyan, off.',
      'It does not change Tokenless compression behavior yet.',
      '```',
      '',
      'Otherwise, show a compact Tokenless dashboard.',
      '',
      'Run these commands:',
      '',
      `1. \`node ${cli} status --user\``,
      `2. \`node ${cli} stats --data-dir ${dir}\``,
      `3. \`node ${cli} latest --data-dir ${dir}\``,
      '',
      'Then answer compactly in this shape:',
      '',
      '```text',
      'Tokenless:',
      '- hooks: installed|not installed',
      '- mode: on|off and source',
      '- local_saved: <tokens_saved> tokens',
      '- local_ratio: <compression_ratio>',
      '- sources: hook=<saved>, eval=<saved>, smoke=<saved>',
      '- read/edit/write packets: <counts and saved tokens>',
      '- gates: pending=<n>',
      '- latest: <artifact_id or none>',
      '- expand: <exact expand command if latest exists>',
      '```',
      '',
      'Do not expand raw artifacts unless the user asks for details.'
    ].join('\n')
  };
}

function installSlashCommands({ dataDir, commandsDir, dryRun }) {
  const targetDir = getSlashCommandsDir({ commandsDir });
  const commands = buildSlashCommands({ cliPath: __filename, dataDir });

  console.log('TOKENLESS-INSTALL-COMMANDS/0.1');
  console.log('scope: user');
  console.log(`commands_dir: ${targetDir}`);
  console.log(`data_dir: ${dataDir}`);
  console.log(`dry_run: ${dryRun ? 'yes' : 'no'}`);

  for (const [fileName, content] of Object.entries(commands)) {
    const targetPath = path.join(targetDir, fileName);
    console.log(`${dryRun ? 'would install' : 'install'}: /${path.basename(fileName, '.md')} -> ${targetPath}`);

    if (dryRun) {
      continue;
    }

    fs.mkdirSync(targetDir, { recursive: true });
    if (fs.existsSync(targetPath)) {
      const backupPath = `${targetPath}.bak-${new Date().toISOString().replace(/[:.]/g, '-')}`;
      fs.copyFileSync(targetPath, backupPath);
      console.log(`backup: ${backupPath}`);
    }
    fs.writeFileSync(targetPath, `${content}\n`, 'utf8');
  }

  if (!dryRun) {
    console.log('installed: yes');
    console.log('restart Claude Code to load /tokenless');
  }
}

function uninstallSlashCommands({ commandsDir, dryRun }) {
  const targetDir = getSlashCommandsDir({ commandsDir });
  const files = ['tokenless.md', 'tokenless-latest.md', 'tokenless-expand.md', 'tokenless-doctor.md', 'tokenless-mode.md'];

  console.log('TOKENLESS-UNINSTALL-COMMANDS/0.1');
  console.log('scope: user');
  console.log(`commands_dir: ${targetDir}`);
  console.log(`dry_run: ${dryRun ? 'yes' : 'no'}`);

  for (const fileName of files) {
    const targetPath = path.join(targetDir, fileName);
    if (!fs.existsSync(targetPath)) {
      console.log(`missing: ${targetPath}`);
      continue;
    }
    console.log(`${dryRun ? 'would remove' : 'remove'}: ${targetPath}`);
    if (!dryRun) {
      fs.rmSync(targetPath, { force: true });
    }
  }

  if (!dryRun) {
    console.log('uninstalled: yes');
    console.log('restart Claude Code to apply the change');
  }
}

function getBenchmarkFixtureDefaults(fixture) {
  const normalized = sanitizeSlug(fixture);
  if (normalized === 'aurora-10k-tsx' || normalized === 'aurora') {
    return {
      fixture: 'aurora-10k-tsx',
      source: '/Users/mac/aurora-ops-10k-tsx-original',
      file: 'src/App.tsx',
      outputPrefix: 'aurora-ops-10k-tsx-benchmark',
      apiPrefix: 'aurora-10k-tsx'
    };
  }
  if (normalized === 'einstein-css' || normalized === 'css') {
    return {
      fixture: 'einstein-css',
      source: '/Users/mac/einstein-observatory-original',
      file: 'style.css',
      outputPrefix: 'einstein-observatory-benchmark',
      apiPrefix: 'einstein-css'
    };
  }
  return null;
}

function chmodUserWritableRecursive(targetPath) {
  if (!fs.existsSync(targetPath)) return;
  const stat = fs.statSync(targetPath);
  fs.chmodSync(targetPath, stat.mode | 0o200);
  if (!stat.isDirectory()) return;
  for (const child of fs.readdirSync(targetPath)) {
    chmodUserWritableRecursive(path.join(targetPath, child));
  }
}

