  }
}

function benchmarkCopy({ fixture, source, outRoot, name, file }) {
  const defaults = getBenchmarkFixtureDefaults(fixture);
  if (!defaults && !source) {
    console.error('tokenless benchmark-copy requires a known fixture or --source <dir>');
    console.error('known fixtures: aurora-10k-tsx, einstein-css');
    process.exit(1);
  }

  const resolvedFixture = defaults ? defaults.fixture : sanitizeSlug(fixture || name || 'custom');
  const sourceDir = path.resolve(source || defaults.source);
  const relativeFile = file || (defaults && defaults.file) || '';
  const outputPrefix = sanitizeSlug(name || (defaults && defaults.outputPrefix) || `${resolvedFixture}-benchmark`);
  const apiPrefix = sanitizeSlug((defaults && defaults.apiPrefix) || resolvedFixture);
  const stamp = timestampSlug();
  const baseDir = path.join(path.resolve(outRoot || os.homedir()), `${outputPrefix}-${stamp}`);
  const onDir = path.join(baseDir, 'on');
  const offDir = path.join(baseDir, 'off');

  if (!fs.existsSync(sourceDir)) {
    console.error(`source not found: ${sourceDir}`);
    process.exit(1);
  }

  fs.mkdirSync(baseDir, { recursive: true });
  fs.cpSync(sourceDir, onDir, { recursive: true });
  fs.cpSync(sourceDir, offDir, { recursive: true });
  chmodUserWritableRecursive(onDir);
  chmodUserWritableRecursive(offDir);

  const onFile = relativeFile ? path.join(onDir, relativeFile) : onDir;
  const offFile = relativeFile ? path.join(offDir, relativeFile) : offDir;

  console.log('TOKENLESS-BENCHMARK-COPY/0.1');
  console.log(`fixture: ${resolvedFixture}`);
  console.log(`source: ${sourceDir}`);
  console.log(`base: ${baseDir}`);
  console.log(`on: ${onDir}`);
  console.log(`off: ${offDir}`);
  if (relativeFile) {
    console.log(`on_file: ${onFile}`);
    console.log(`off_file: ${offFile}`);
    if (fs.existsSync(onFile)) {
      const lines = fs.readFileSync(onFile, 'utf8').split(/\r?\n/).length;
      console.log(`lines: ${lines}`);
    }
  }
  printBenchmarkCommands({ fixture: resolvedFixture, onFile, offFile, apiPrefix });
}

function printStatus({ scope, settingsPath }) {
  const targetPath = getSettingsPath(scope, settingsPath);
  const rawMode = String(process.env.TOKENLESS_MODE || 'on').trim() || 'on';
  const disabled = /^(0|false|off|disabled)$/i.test(rawMode);
  console.log('TOKENLESS-STATUS/0.1');
  console.log(`scope: ${scope || 'custom'}`);
  console.log(`settings: ${targetPath}`);
  console.log(`mode: ${disabled ? 'off' : 'on'}`);
  console.log(`mode_source: ${process.env.TOKENLESS_MODE ? 'TOKENLESS_MODE' : 'default'}`);
  console.log(`mode_raw: ${rawMode}`);
  console.log(`settings_exists: ${fs.existsSync(targetPath) ? 'yes' : 'no'}`);

  if (!fs.existsSync(targetPath)) {
    console.log('installed: no');
    return;
  }

  const settings = JSON.parse(fs.readFileSync(targetPath, 'utf8'));
  const status = getHookInstallStatus(settings);
  console.log(`installed: ${status.installed ? 'yes' : 'no'}`);
  for (const [hookName, installed] of Object.entries(status.detail)) {
    console.log(`${hookName}: ${installed ? 'yes' : 'no'}`);
  }
}

function cleanArtifacts({ dataDir, keep, olderThan, dryRun }) {
  const artifacts = listArtifacts(dataDir);
  const olderThanMs = parseDurationMs(olderThan);
  const cutoff = olderThanMs == null ? null : Date.now() - olderThanMs;
  const toDelete = [];

  for (let i = 0; i < artifacts.length; i++) {
    const artifact = artifacts[i];
    const removeByKeep = keep != null && i >= keep;
    const created = Date.parse(artifact.created_at || '');
    const removeByAge = cutoff != null && Number.isFinite(created) && created < cutoff;

    if (removeByKeep || removeByAge) {
      toDelete.push({
        artifact,
        reason: removeByKeep && removeByAge ? 'keep+age' : (removeByKeep ? 'keep' : 'age')
      });
    }
  }

  console.log('TOKENLESS-CLEAN/0.1');
  console.log(`data_dir: ${dataDir}`);
  console.log(`artifacts: ${artifacts.length}`);
  console.log(`delete: ${toDelete.length}`);
  console.log(`dry_run: ${dryRun ? 'yes' : 'no'}`);

  if (!toDelete.length) return;

  const artifactRoot = path.join(path.resolve(dataDir), 'artifacts');
  for (const item of toDelete) {
    const artifactId = item.artifact.artifact_id;
    console.log(`${dryRun ? 'would delete' : 'deleted'} ${artifactId} (${item.reason})`);
    if (!dryRun) {
      fs.rmSync(path.join(artifactRoot, artifactId), { recursive: true, force: true });
    }
  }
}

function commandContainsShellSyntax(parts) {
  return parts.some((item) => ['&&', '||', ';', '|', '>', '<', '|&'].includes(item));
}

function normalizeCommandArgs(commandParts) {
  const [command, ...rest] = commandParts;
  if (!command) {
    return { command, args: [], useShell: false, shellCommand: '' };
  }

  // Special-case node -e / node -p style where script may include spaces that shell originally preserved.
  const mergedRest = [...rest];
  if ((command === 'node' || command === 'python' || command === 'python3') && mergedRest.length > 1 && mergedRest[0] === '-e') {
    mergedRest[1] = mergedRest.slice(1).join(' ');
    while (mergedRest.length > 2) {
      mergedRest.pop();
    }
  }

  if (commandContainsShellSyntax(mergedRest)) {
    return {
      command,
      args: mergedRest,
      useShell: true,
      shellCommand: `${command} ${mergedRest.join(' ')}`
    };
  }

  return { command, args: mergedRest, useShell: false, shellCommand: '' };
}

async function runCommand(parsed) {
  const { command, args, useShell, shellCommand } = parsed;
  return new Promise((resolve) => {
    const child = spawn(
      useShell ? shellCommand : command,
      useShell ? [] : args,
      {
      shell: useShell,
      stdio: ['ignore', 'pipe', 'pipe'],
      windowsHide: true
    });

    let stdout = '';
    let stderr = '';

    child.stdout.on('data', (chunk) => {
      stdout += chunk.toString();
    });

    child.stderr.on('data', (chunk) => {
      stderr += chunk.toString();
    });

    child.on('error', (err) => {
      stderr += `\n[tokenless-run:spawn-error] ${err.message}`;
    });

    child.on('close', (code) => {
      resolve({ code, stdout, stderr, interrupted: false, isImage: false });
    });
  });
}

function showArtifact(artifactId, dataDir) {
  const resolvedArtifactId = resolveArtifactId(artifactId, dataDir);
  const artifact = readArtifact(dataDir, resolvedArtifactId);
  if (!artifact) {
    console.error(`artifact not found: ${resolvedArtifactId}`);
    process.exit(1);
  }

  process.stdout.write(`artifact_id: ${artifact.meta.artifact_id}\n`);
  process.stdout.write(`created_at: ${artifact.meta.created_at}\n`);
  process.stdout.write(`command: ${artifact.meta.command}\n`);
  process.stdout.write(`status: ${artifact.meta.status}\n`);
  process.stdout.write(`cwd: ${artifact.meta.cwd}\n`);
  process.stdout.write('--- RAW STDOUT ---\n');
  process.stdout.write(artifact.stdout);
  if (artifact.stdout && !artifact.stdout.endsWith('\n')) process.stdout.write('\n');
  process.stdout.write('--- RAW STDERR ---\n');
  process.stdout.write(artifact.stderr);
  if (artifact.stderr && !artifact.stderr.endsWith('\n')) process.stdout.write('\n');
}

function getExpandBudgetPath(dataDir) {
  const base = path.resolve(dataDir || path.join(os.homedir(), '.tokenless'));
  fs.mkdirSync(base, { recursive: true });
  return path.join(base, 'expand_budget_index.json');
}

function readExpandBudgetIndex(dataDir) {
  const indexPath = getExpandBudgetPath(dataDir);
  if (!fs.existsSync(indexPath)) return {};
  try {
    const parsed = JSON.parse(fs.readFileSync(indexPath, 'utf8'));
    return parsed && typeof parsed === 'object' ? parsed : {};
  } catch (err) {
    return {};
  }
}

function writeExpandBudgetIndex(dataDir, index) {
  fs.writeFileSync(getExpandBudgetPath(dataDir), JSON.stringify(index || {}, null, 2), 'utf8');
}

function recordExpandLookup(dataDir, artifactId, artifact) {
  if (!artifact || !artifact.meta || artifact.meta.reducer !== 'read-packet') {
    return { count: 0, applies: false };
  }

  const index = readExpandBudgetIndex(dataDir);
  const key = String(artifactId || artifact.meta.artifact_id || '');
  const entry = index[key] || {
    artifact_id: key,
    created_at: new Date().toISOString(),
    count: 0
  };
  entry.count = (Number(entry.count) || 0) + 1;
  entry.updated_at = new Date().toISOString();
  index[key] = entry;
  writeExpandBudgetIndex(dataDir, index);
  return { count: entry.count, applies: true };
}

function formatExpandWithBudget(expanded, budget) {
  const body = expanded || 'No matching lines\n';
  if (!budget.applies || budget.count <= 2) return body;

  if (budget.count === 3) {
    return [
      'TOKENLESS-EXPAND-BUDGET-WARNING/0.1',
      'Budget: this is the 3rd lookup for the same read packet.',
      'Guidance: if this is a broad style/edit task, stop exploring and edit from the existing snippets.',
      '',
      body
    ].join('\n');
  }

  const compactLines = String(body).split(/\r?\n/).slice(0, 28).join('\n');
  return [
    'TOKENLESS-EXPAND-BUDGET-COMPACT/0.1',
    `Budget: lookup #${budget.count} for the same read packet.`,
    'Guidance: continuing to inspect is likely more expensive than editing. This lookup is compacted, not blocked.',
    'Escape hatch: if the user requested exact review/security/legal/syntax validation, run the same expand again only after explaining why the extra context is required.',
    '',
    compactLines,
    compactLines.endsWith('\n') ? '' : '\n'
  ].join('\n');
}

function formatReadReusePacket({ filePath, dataDir, state }) {
  const entry = state && state.entry ? state.entry : {};
  const artifactId = entry.artifact_id || '(unknown)';
  const commandPrefix = `node ${shellQuote(__filename)}`;
  const dataDirPart = ` --data-dir ${shellQuote(dataDir)}`;
  return [
    'TOKENLESS-READ-REUSE/0.1',
    '',
    `File: ${filePath}`,
    `Existing artifact: ${artifactId}`,
    'Reason: this file already has a fresh read packet; creating another packet usually expands model trajectory without adding information.',
    '',
    'Next actions:',
    '- Edit/MultiEdit from the existing packet snippets when possible.',
    '- If exact text is missing, use at most two targeted expand lookups:',
    `  1. ${commandPrefix} expand ${artifactId} --around "<selector-or-text>"${dataDirPart}`,
    `  2. ${commandPrefix} expand ${artifactId} --lines <start:end>${dataDirPart}`,
    '- Do not rerun tokenless read for this file unless Tokenless reports TOKENLESS-STALE or the file changed.',
    ''
  ].join('\n');
}

function expandArtifact(artifactId, keyword, dataDir) {
  const resolvedArtifactId = resolveArtifactId(artifactId, dataDir);
  const artifact = readArtifact(dataDir, resolvedArtifactId);
  if (!artifact) {
    console.error(`artifact not found: ${resolvedArtifactId}`);
    process.exit(1);
  }

  if (!keyword) {
    console.error('missing --around keyword');
    process.exit(1);
  }

  const expanded = expandArtifactAround(artifact, keyword);
  const budget = recordExpandLookup(dataDir, resolvedArtifactId, artifact);
  process.stdout.write(formatExpandWithBudget(expanded, budget));
}

function expandArtifactByLines(artifactId, lines, dataDir) {
  const resolvedArtifactId = resolveArtifactId(artifactId, dataDir);
  const artifact = readArtifact(dataDir, resolvedArtifactId);
  if (!artifact) {
    console.error(`artifact not found: ${resolvedArtifactId}`);
    process.exit(1);
  }

  if (!lines) {
    console.error('missing --lines range');
    process.exit(1);
  }

  const expanded = expandArtifactLines(artifact, lines);
  const budget = recordExpandLookup(dataDir, resolvedArtifactId, artifact);
  process.stdout.write(formatExpandWithBudget(expanded, budget));
}

function formatPercent(numerator, denominator) {
  if (!denominator) return '0%';
  return `${((numerator / denominator) * 100).toFixed(1).replace(/\.0$/, '')}%`;
}

function printStats(dataDir) {
  const entries = readStatsEntries(dataDir);
  const summary = summarizeStats(entries);
  const observations = readObservationEntries(dataDir);
  const observedSummary = summarizeObservations(observations);
  const compressionRatio = formatPercent(summary.tokens_after, summary.tokens_before);
  const savedRatio = formatPercent(summary.tokens_saved, summary.tokens_before);

  console.log('TOKENLESS-STATS/0.1');
  console.log(`data_dir: ${dataDir}`);
  console.log('measurement_scope: local_hook_boundary');
  console.log('measurement_note: before/after is local compression delta; use api-probe stats for API-confirmed evidence');
  console.log(`calls: ${summary.calls}`);
  console.log(`success: ${summary.success}`);
  console.log(`failed: ${summary.failed}`);
  console.log(`tokens_before: ${summary.tokens_before}`);
  console.log(`tokens_after: ${summary.tokens_after}`);
  console.log(`tokens_saved: ${summary.tokens_saved}`);
  console.log(`local_tokens_before: ${summary.tokens_before}`);
  console.log(`local_tokens_after: ${summary.tokens_after}`);
  console.log(`local_tokens_saved: ${summary.tokens_saved}`);
  console.log(`compression_ratio: ${compressionRatio}`);
  console.log(`saved_ratio: ${savedRatio}`);
  console.log(`bytes_stdout: ${summary.bytes_stdout}`);
  console.log(`bytes_stderr: ${summary.bytes_stderr}`);
  console.log('');
  console.log('By reducer:');

  const reducers = Object.entries(summary.by_reducer).sort((a, b) => {
    return b[1].tokens_saved - a[1].tokens_saved;
  });

  if (!reducers.length) {
    console.log('- (none)');
  } else {
    for (const [reducer, item] of reducers) {
      console.log(`- ${reducer}: calls=${item.calls}, before=${item.tokens_before}, after=${item.tokens_after}, saved=${item.tokens_saved}, ratio=${formatPercent(item.tokens_after, item.tokens_before)}`);
    }
  }

  console.log('');
  console.log('By source:');
  const sources = Object.entries(summary.by_source || {}).sort((a, b) => {
    return b[1].tokens_saved - a[1].tokens_saved;
  });

  if (!sources.length) {
    console.log('- (none)');
  } else {
    for (const [source, item] of sources) {
      console.log(`- ${source}: calls=${item.calls}, before=${item.tokens_before}, after=${item.tokens_after}, saved=${item.tokens_saved}, ratio=${formatPercent(item.tokens_after, item.tokens_before)}`);
    }
  }

  const realHook = (summary.by_source || {}).hook;
  console.log('');
  console.log('Real hook savings:');
  if (realHook) {
    console.log(`- calls: ${realHook.calls}`);
    console.log(`- tokens_before: ${realHook.tokens_before}`);
    console.log(`- tokens_after: ${realHook.tokens_after}`);
    console.log(`- tokens_saved: ${realHook.tokens_saved}`);
    console.log(`- ratio: ${formatPercent(realHook.tokens_after, realHook.tokens_before)}`);
  } else {
    console.log('- (none)');
  }

  const readPacket = summary.by_reducer['read-packet'];
  const editPacket = summary.by_reducer['edit-packet'];
  const writePacket = summary.by_reducer['write-packet'];
  console.log('');
  console.log('Read packet savings:');
  if (readPacket) {
    console.log(`- calls: ${readPacket.calls}`);
    console.log(`- tokens_before: ${readPacket.tokens_before}`);
    console.log(`- tokens_after: ${readPacket.tokens_after}`);
    console.log(`- tokens_saved: ${readPacket.tokens_saved}`);
    console.log(`- ratio: ${formatPercent(readPacket.tokens_after, readPacket.tokens_before)}`);
  } else {
    console.log('- (none)');
  }

  console.log('');
  console.log('Edit/Write packet savings:');
  if (editPacket) {
    console.log(`- edit-packet: calls=${editPacket.calls}, before=${editPacket.tokens_before}, after=${editPacket.tokens_after}, saved=${editPacket.tokens_saved}, ratio=${formatPercent(editPacket.tokens_after, editPacket.tokens_before)}`);
  } else {
    console.log('- edit-packet: (none)');
  }
  if (writePacket) {
    console.log(`- write-packet: calls=${writePacket.calls}, before=${writePacket.tokens_before}, after=${writePacket.tokens_after}, saved=${writePacket.tokens_saved}, ratio=${formatPercent(writePacket.tokens_after, writePacket.tokens_before)}`);
  } else {
    console.log('- write-packet: (none)');
  }

  const recent = entries.slice(-5).reverse();
  console.log('');
  console.log('Recent:');
  if (!recent.length) {
    console.log('- (none)');
  } else {
    for (const entry of recent) {
      const before = Number(entry.tokens_before) || 0;
      const after = Number(entry.tokens_after) || 0;
      const saved = Number(entry.tokens_saved) || (before - after);
      const source = normalizeStatsSource(entry.source || 'legacy');
      console.log(`- ${entry.artifact_id}: [${source}] ${entry.status || 'unknown'} ${entry.reducer || 'unknown'} ${before}->${after} saved=${saved}`);
    }
  }

  const gates = listReadGates(dataDir);
  const packets = listReadPackets(dataDir);
  console.log('');
  console.log('Large read gates:');
  console.log(`- pending: ${gates.length}`);
  if (gates.length) {
    for (const gate of gates.slice(0, 5)) {
      console.log(`- ${gate.file_path}: estimated=${gate.estimated_tokens} reason=${gate.reason || 'unknown'}`);
    }
  }
  console.log(`- packet_index: ${packets.length}`);
  if (packets.length) {
    for (const packet of packets.slice(-5).reverse()) {
      console.log(`- ${packet.artifact_id || '(no artifact)'}: ${packet.file_path} tokens=${packet.estimated_tokens || 0}`);
    }
  }

  console.log('');
  console.log('Observed tool outputs:');
  console.log(`- calls: ${observedSummary.calls}`);
  console.log(`- large_outputs: ${observedSummary.large_outputs}`);
  console.log(`- max_response_tokens: ${observedSummary.max_response_tokens}`);
  const observedTools = Object.entries(observedSummary.by_tool).sort((a, b) => b[1].calls - a[1].calls);
  if (!observedTools.length) {
    console.log('- by_tool: (none)');
  } else {
    for (const [tool, item] of observedTools) {
      console.log(`- ${tool}: calls=${item.calls}, large=${item.large_outputs}, response_tokens=${item.response_tokens}, max_response=${item.max_response_tokens}`);
    }
  }
}

function parseDurationToMs(value) {
  if (!value) return null;
  const match = String(value).trim().match(/^(\d+)(m|h|d)$/i);
  if (!match) return null;
  const amount = Number(match[1]);
  const unit = match[2].toLowerCase();
  if (unit === 'm') return amount * 60 * 1000;
  if (unit === 'h') return amount * 60 * 60 * 1000;
  return amount * 24 * 60 * 60 * 1000;
}

function walkFiles(root, predicate) {
  const out = [];
  if (!fs.existsSync(root)) return out;
  const stack = [root];

  while (stack.length) {
    const current = stack.pop();
    let stat;
    try {
      stat = fs.statSync(current);
    } catch (err) {
      continue;
    }

    if (stat.isDirectory()) {
      let entries = [];
      try {
        entries = fs.readdirSync(current);
      } catch (err) {
        continue;
      }
      for (const entry of entries) {
        stack.push(path.join(current, entry));
      }
      continue;
    }

    if (!stat.isFile()) continue;
    if (!predicate || predicate(current)) out.push(current);
  }

  return out;
}

function getEventTimeMs(value) {
  const candidates = [
    value && value.timestamp,
    value && value.created_at,
    value && value.createdAt,
    value && value.message && value.message.created_at,
    value && value.message && value.message.timestamp
  ].filter(Boolean);

  for (const item of candidates) {
    const parsed = Date.parse(item);
    if (Number.isFinite(parsed)) return parsed;
  }
  return null;
}

function getModelName(value) {
  return (value && (value.model || (value.message && value.message.model))) || 'unknown';
}

function hasUsageShape(value) {
  return value && typeof value === 'object' && (
    Object.prototype.hasOwnProperty.call(value, 'input_tokens') ||
    Object.prototype.hasOwnProperty.call(value, 'output_tokens') ||
    Object.prototype.hasOwnProperty.call(value, 'cache_creation_input_tokens') ||
    Object.prototype.hasOwnProperty.call(value, 'cache_read_input_tokens') ||
    Object.prototype.hasOwnProperty.call(value, 'cache_creation_tokens') ||
    Object.prototype.hasOwnProperty.call(value, 'cache_read_tokens')
  );
}

function normalizeUsage(value) {
  return {
    input_tokens: Number(value.input_tokens) || 0,
    output_tokens: Number(value.output_tokens) || 0,
    cache_creation_tokens: Number(value.cache_creation_input_tokens || value.cache_creation_tokens) || 0,
    cache_read_tokens: Number(value.cache_read_input_tokens || value.cache_read_tokens) || 0
  };
}

function collectUsageObjects(value, out = []) {
  if (!value || typeof value !== 'object') return out;

  if (hasUsageShape(value.usage)) {
    out.push(value.usage);
  }

  if (hasUsageShape(value)) {
    out.push(value);
    return out;
  }

  for (const child of Object.values(value)) {
    if (child && typeof child === 'object') collectUsageObjects(child, out);
  }

  return out;
}

function findLatestFile(root) {
  const files = walkFiles(root);
  let latest = null;

  for (const filePath of files) {
    let stat;
    try {
      stat = fs.statSync(filePath);
    } catch (err) {
      continue;
    }
    if (!latest || stat.mtimeMs > latest.mtimeMs) {
      latest = { filePath, mtimeMs: stat.mtimeMs, size: stat.size };
    }
  }

  return latest;
}

function summarizeJsonShape(value, depth = 0, seen = new Set()) {
  if (value == null) return String(value);
  if (typeof value !== 'object') return typeof value;
  if (seen.has(value)) return '[Circular]';
  if (depth >= 3) return Array.isArray(value) ? `Array(${value.length})` : `Object(${Object.keys(value).length})`;
  seen.add(value);

  if (Array.isArray(value)) {
    const sample = value.length ? summarizeJsonShape(value[0], depth + 1, seen) : 'empty';
    return `Array(${value.length})<${sample}>`;
  }

  const entries = Object.entries(value).slice(0, 20).map(([key, child]) => {
    return `${key}: ${summarizeJsonShape(child, depth + 1, seen)}`;
  });
  return `{ ${entries.join(', ')}${Object.keys(value).length > 20 ? ', ...' : ''} }`;
}

function collectMessageStats(value) {
  const stats = {
    arrays_named_messages: 0,
    message_items: 0,
    roles: {},
    largest_string_chars: 0,
    largest_string_path: null
  };

  function visit(node, pathParts = []) {
    if (typeof node === 'string') {
      if (node.length > stats.largest_string_chars) {
        stats.largest_string_chars = node.length;
        stats.largest_string_path = pathParts.join('.');
      }
      return;
    }
    if (!node || typeof node !== 'object') return;

    if (Array.isArray(node)) {
      if (pathParts[pathParts.length - 1] === 'messages') {
        stats.arrays_named_messages += 1;
        stats.message_items += node.length;
      }
      node.forEach((item, index) => visit(item, [...pathParts, String(index)]));
      return;
    }

    if (typeof node.role === 'string') {
      stats.roles[node.role] = (stats.roles[node.role] || 0) + 1;
    }

    for (const [key, child] of Object.entries(node)) {
      visit(child, [...pathParts, key]);
    }
  }

  visit(value);
  return stats;
}

function findKeywordSnippet(text, keyword) {
  if (!keyword) return null;
  const index = text.indexOf(keyword);
  if (index < 0) return null;
  const start = Math.max(0, index - 160);
  const end = Math.min(text.length, index + keyword.length + 160);
  return text.slice(start, end)
    .replace(/[A-Za-z0-9+/=]{40,}/g, '[long-token-redacted]')
    .replace(/(sk-ant-[A-Za-z0-9_-]+)/g, '[api-key-redacted]');
}

function classifyApiProbeFile(filePath) {
  const name = path.basename(filePath).toLowerCase();
  if (name.includes('request')) return 'request';
  if (name.includes('response')) return 'response';
  return 'other';
}

function makeApiProbeBucket() {
  return {
    files: 0,
    bytes: 0,
    estimated_tokens: 0,
    largest: []
  };
}

function addLargestApiProbeFile(bucket, item) {
  bucket.largest.push(item);
  bucket.largest.sort((a, b) => b.estimated_tokens - a.estimated_tokens);
  bucket.largest = bucket.largest.slice(0, 8);
}

function countKeywordInText(text, keyword) {
  if (!keyword) return 0;
  return String(text || '').split(keyword).length - 1;
}

function extractArtifactIds(text) {
  return Array.from(new Set(String(text || '').match(/ctx_\d{8}_\d{6}_[a-z0-9]+/g) || []));
}

function makeConfirmedSavingsBucket() {
  return {
    artifacts: 0,
    request_appearances: 0,
    unique_saved_tokens: 0,
    request_saved_estimate: 0
  };
}

function addConfirmedSavings(summary, reducer, saved, appearances) {
  if (!summary.by_reducer[reducer]) {
    summary.by_reducer[reducer] = makeConfirmedSavingsBucket();
  }
  const bucket = summary.by_reducer[reducer];
  bucket.artifacts += 1;
  bucket.request_appearances += appearances;
  bucket.unique_saved_tokens += saved;
  bucket.request_saved_estimate += saved * appearances;
}

function summarizeApiConfirmedSavings({ requestArtifactFiles, dataDir }) {
  const entries = readStatsEntries(dataDir);
  const statsByArtifact = new Map();

  for (const entry of entries) {
    if (!entry || !entry.artifact_id) continue;
    statsByArtifact.set(entry.artifact_id, entry);
  }

  const artifactRequestCounts = new Map();
  for (const [artifactId, fileSet] of requestArtifactFiles.entries()) {
    artifactRequestCounts.set(artifactId, fileSet.size);
  }

  const summary = {
    data_dir: dataDir,
    artifacts_observed_in_requests: artifactRequestCounts.size,
    artifacts_with_local_stats: 0,
    request_appearances: 0,
    unique_saved_tokens: 0,
    request_saved_estimate: 0,
    by_reducer: {}
  };

  for (const [artifactId, appearances] of artifactRequestCounts.entries()) {
    const entry = statsByArtifact.get(artifactId);
    if (!entry) continue;
    const before = Number(entry.tokens_before) || 0;
    const after = Number(entry.tokens_after) || 0;
    const saved = Number(entry.tokens_saved) || Math.max(0, before - after);
    const reducer = entry.reducer || 'unknown';

    summary.artifacts_with_local_stats += 1;
    summary.request_appearances += appearances;
    summary.unique_saved_tokens += saved;
    summary.request_saved_estimate += saved * appearances;
    addConfirmedSavings(summary, reducer, saved, appearances);
  }

  return summary;
}

function printApiProbeStats({ dir, dataDir }) {
  const files = walkFiles(dir, (filePath) => filePath.endsWith('.json'));
  const requestArtifactFiles = new Map();
  const summary = {
    all: makeApiProbeBucket(),
    request: makeApiProbeBucket(),
    response: makeApiProbeBucket(),
    other: makeApiProbeBucket(),
    keywords: {}
  };
  const keywords = [
    'TOKENLESS-READ-PACKET',
    'TOKENLESS-EDIT-PACKET',
    'TOKENLESS-WRITE-PACKET',
    'NEXT REQUIRED COMMAND',
    'blocked before execution',
    'stale',
    'originalFile',
    'structuredPatch',
    'oldString',
    'newString',
    'tool_result'
  ];

  for (const keyword of keywords) {
    summary.keywords[keyword] = {
      request_matches: 0,
      response_matches: 0,
      other_matches: 0,
      files_with_matches: 0
    };
  }

  for (const filePath of files) {
    let text = '';
    let stat;
    try {
      stat = fs.statSync(filePath);
      text = fs.readFileSync(filePath, 'utf8');
    } catch (err) {
      continue;
    }

    const kind = classifyApiProbeFile(filePath);
    const tokens = estimateTokens(text);
    const item = {
      filePath,
      bytes: stat.size,
      estimated_tokens: tokens,
      has_read_packet: text.includes('TOKENLESS-READ-PACKET'),
      has_edit_packet: text.includes('TOKENLESS-EDIT-PACKET'),
      has_write_packet: text.includes('TOKENLESS-WRITE-PACKET'),
      has_raw_edit_payload: text.includes('originalFile') || text.includes('structuredPatch')
    };

    if (kind === 'request') {
      for (const artifactId of extractArtifactIds(text)) {
        if (!requestArtifactFiles.has(artifactId)) requestArtifactFiles.set(artifactId, new Set());
        requestArtifactFiles.get(artifactId).add(filePath);
      }
    }

    for (const bucket of [summary.all, summary[kind]]) {
      bucket.files += 1;
      bucket.bytes += stat.size;
      bucket.estimated_tokens += tokens;
      addLargestApiProbeFile(bucket, item);
    }

    for (const keyword of keywords) {
      const count = countKeywordInText(text, keyword);
      if (!count) continue;
      summary.keywords[keyword].files_with_matches += 1;
      if (kind === 'request') summary.keywords[keyword].request_matches += count;
      else if (kind === 'response') summary.keywords[keyword].response_matches += count;
      else summary.keywords[keyword].other_matches += count;
    }
  }

  const confirmed = summarizeApiConfirmedSavings({ requestArtifactFiles, dataDir });

  console.log('TOKENLESS-API-PROBE-STATS/0.1');
  console.log(`dir: ${dir}`);
  console.log(`data_dir: ${dataDir}`);
  console.log(`files_scanned: ${files.length}`);
  console.log('');
  console.log('Estimated API body size:');
  for (const name of ['request', 'response', 'other', 'all']) {
    const bucket = summary[name];
    console.log(`- ${name}: files=${bucket.files}, bytes=${bucket.bytes}, estimated_tokens=${bucket.estimated_tokens}`);
  }
  console.log('');
  console.log('Packet evidence:');
  for (const keyword of ['TOKENLESS-READ-PACKET', 'TOKENLESS-EDIT-PACKET', 'TOKENLESS-WRITE-PACKET', 'NEXT REQUIRED COMMAND', 'blocked before execution', 'stale']) {
    const item = summary.keywords[keyword];
    console.log(`- ${keyword}: request=${item.request_matches}, response=${item.response_matches}, other=${item.other_matches}, files=${item.files_with_matches}`);
  }
  console.log('');
  console.log('Raw leak checks:');
  for (const keyword of ['originalFile', 'structuredPatch', 'oldString', 'newString', 'tool_result']) {
    const item = summary.keywords[keyword];
    console.log(`- ${keyword}: request=${item.request_matches}, response=${item.response_matches}, other=${item.other_matches}, files=${item.files_with_matches}`);
  }
  console.log('');
  console.log('API-confirmed savings estimate:');
  console.log('- basis: artifact ids observed in API request bodies joined with local before/after stats');
  console.log('- caveat: request_saved_estimate is request-body counterfactual, not exact billed-token savings');
  console.log(`- artifacts_observed_in_requests: ${confirmed.artifacts_observed_in_requests}`);
  console.log(`- artifacts_with_local_stats: ${confirmed.artifacts_with_local_stats}`);
  console.log(`- request_appearances: ${confirmed.request_appearances}`);
  console.log(`- unique_saved_tokens: ${confirmed.unique_saved_tokens}`);
  console.log(`- request_saved_estimate: ${confirmed.request_saved_estimate}`);
  console.log('- by_reducer:');
  const confirmedReducers = Object.entries(confirmed.by_reducer).sort((a, b) => b[1].request_saved_estimate - a[1].request_saved_estimate);
  if (!confirmedReducers.length) {
    console.log('  - (none)');
  } else {
    for (const [reducer, item] of confirmedReducers) {
      console.log(`  - ${reducer}: artifacts=${item.artifacts}, appearances=${item.request_appearances}, unique_saved=${item.unique_saved_tokens}, request_saved_estimate=${item.request_saved_estimate}`);
    }
  }
  console.log('');
  console.log('Largest request files:');
  if (!summary.request.largest.length) {
    console.log('- (none)');
  } else {
    for (const item of summary.request.largest) {
      console.log(`- ${item.filePath}: tokens=${item.estimated_tokens}, read_packet=${item.has_read_packet ? 'yes' : 'no'}, edit_packet=${item.has_edit_packet ? 'yes' : 'no'}, write_packet=${item.has_write_packet ? 'yes' : 'no'}, raw_edit_payload=${item.has_raw_edit_payload ? 'yes' : 'no'}`);
    }
  }
}

function printApiUsage({ source, since }) {
  const sinceMs = parseDurationToMs(since);
  const cutoff = sinceMs == null ? null : Date.now() - sinceMs;
  const files = walkFiles(source, (filePath) => filePath.endsWith('.jsonl'));
  const summary = {
    files_scanned: files.length,
    rows_scanned: 0,
    rows_with_usage: 0,
    usage_events: 0,
    input_tokens: 0,
    output_tokens: 0,
    cache_creation_tokens: 0,
    cache_read_tokens: 0,
    total_tokens: 0,
    latest_at: null,
    by_model: {}
  };

  for (const filePath of files) {
    let lines = [];
    try {
      lines = fs.readFileSync(filePath, 'utf8').split(/\r?\n/).filter(Boolean);
    } catch (err) {
      continue;
    }

    for (const line of lines) {
      summary.rows_scanned += 1;
      let row;
      try {
        row = JSON.parse(line);
      } catch (err) {
        continue;
      }

      const eventTime = getEventTimeMs(row);
      if (cutoff != null && eventTime != null && eventTime < cutoff) continue;
      if (eventTime != null && (!summary.latest_at || eventTime > Date.parse(summary.latest_at))) {
        summary.latest_at = new Date(eventTime).toISOString();
      }

      const usages = collectUsageObjects(row);
      if (!usages.length) continue;
      summary.rows_with_usage += 1;
      const model = getModelName(row);
      if (!summary.by_model[model]) {
        summary.by_model[model] = {
          usage_events: 0,
          input_tokens: 0,
          output_tokens: 0,
          cache_creation_tokens: 0,
          cache_read_tokens: 0,
          total_tokens: 0
        };
      }

      for (const usage of usages) {
        const normalized = normalizeUsage(usage);
        const total = normalized.input_tokens + normalized.output_tokens + normalized.cache_creation_tokens + normalized.cache_read_tokens;
        summary.usage_events += 1;
        summary.input_tokens += normalized.input_tokens;
        summary.output_tokens += normalized.output_tokens;
        summary.cache_creation_tokens += normalized.cache_creation_tokens;
        summary.cache_read_tokens += normalized.cache_read_tokens;
        summary.total_tokens += total;
        summary.by_model[model].usage_events += 1;
        summary.by_model[model].input_tokens += normalized.input_tokens;
        summary.by_model[model].output_tokens += normalized.output_tokens;
        summary.by_model[model].cache_creation_tokens += normalized.cache_creation_tokens;
        summary.by_model[model].cache_read_tokens += normalized.cache_read_tokens;
        summary.by_model[model].total_tokens += total;
      }
    }
  }

  console.log('TOKENLESS-API-USAGE/0.1');
  console.log(`source: ${source}`);
  console.log(`since: ${since || 'all'}`);
  console.log(`files_scanned: ${summary.files_scanned}`);
  console.log(`rows_scanned: ${summary.rows_scanned}`);
  console.log(`rows_with_usage: ${summary.rows_with_usage}`);
  console.log(`usage_events: ${summary.usage_events}`);
  console.log(`input_tokens: ${summary.input_tokens}`);
  console.log(`output_tokens: ${summary.output_tokens}`);
  console.log(`cache_creation_tokens: ${summary.cache_creation_tokens}`);
  console.log(`cache_read_tokens: ${summary.cache_read_tokens}`);
  console.log(`total_tokens: ${summary.total_tokens}`);
  console.log(`latest_at: ${summary.latest_at || 'unknown'}`);
  console.log('');
  console.log('By model:');
  const models = Object.entries(summary.by_model).sort((a, b) => b[1].total_tokens - a[1].total_tokens);
  if (!models.length) {
    console.log('- (none)');
  } else {
    for (const [model, item] of models) {
      console.log(`- ${model}: events=${item.usage_events}, total=${item.total_tokens}, input=${item.input_tokens}, output=${item.output_tokens}, cache_create=${item.cache_creation_tokens}, cache_read=${item.cache_read_tokens}`);
    }
  }
}

function printApiProbe({ action, dir, dataDir, keyword, showSnippet }) {
  if (action === 'start') {
    fs.mkdirSync(dir, { recursive: true });
    console.log('TOKENLESS-API-PROBE/0.1');
    console.log('action: start');
    console.log(`dir: ${dir}`);
    console.log('');
    console.log('Run these before starting Claude Code:');
    console.log(`export TOKENLESS_API_PROBE_DIR=${shellQuote(dir)}`);
    console.log(`export CLAUDE_CODE_ENABLE_TELEMETRY=1`);
    console.log('export OTEL_LOG_RAW_API_BODIES="file:$TOKENLESS_API_PROBE_DIR"');
    console.log('');
    console.log('Warning: raw API bodies can contain full prompts, tool outputs, and sensitive context. Use temporarily and keep local.');
    return;
  }

  if (action === 'stop') {
    console.log('TOKENLESS-API-PROBE/0.1');
    console.log('action: stop');
    console.log('');
    console.log('Run these before starting Claude Code again:');
    console.log('unset OTEL_LOG_RAW_API_BODIES');
    console.log('unset CLAUDE_CODE_ENABLE_TELEMETRY');
    return;
  }

  if (action === 'inspect') {
    if (!keyword) {
      console.error('tokenless api-probe inspect requires --keyword <text>');
      process.exit(1);
    }

    const files = walkFiles(dir);
    let filesWithMatches = 0;
    let totalMatches = 0;
    const samples = [];

    for (const filePath of files) {
      let text = '';
      try {
        text = fs.readFileSync(filePath, 'utf8');
      } catch (err) {
        continue;
      }

      const count = text.split(keyword).length - 1;
      if (count <= 0) continue;
      filesWithMatches += 1;
      totalMatches += count;
      if (samples.length < 10) {
        samples.push({ filePath, count });
      }
    }

    console.log('TOKENLESS-API-PROBE/0.1');
    console.log('action: inspect');
    console.log(`dir: ${dir}`);
    console.log(`keyword: ${keyword}`);
    console.log(`files_scanned: ${files.length}`);
    console.log(`files_with_matches: ${filesWithMatches}`);
    console.log(`matches: ${totalMatches}`);
    console.log('');
    console.log('Sample files:');
    if (!samples.length) {
      console.log('- (none)');
    } else {
      for (const item of samples) {
        console.log(`- ${item.filePath}: ${item.count}`);
      }
    }
    return;
  }

  if (action === 'latest') {
    const latest = findLatestFile(dir);
    console.log('TOKENLESS-API-PROBE/0.1');
    console.log('action: latest');
    console.log(`dir: ${dir}`);

    if (!latest) {
      console.log('file: (none)');
      return;
    }

    let text = '';
    try {
      text = fs.readFileSync(latest.filePath, 'utf8');
    } catch (err) {
      console.log(`file: ${latest.filePath}`);
      console.log(`read_error: ${err.message}`);
      return;
    }

    let parsed = null;
    try {
      parsed = JSON.parse(text);
    } catch (err) {
      // Raw body logs may be JSONL or plain text depending on the exporter.
    }

    const keywordList = ['originalFile', 'structuredPatch', 'oldString', 'newString', 'tool_result', 'messages'];
    if (keyword && !keywordList.includes(keyword)) keywordList.unshift(keyword);

    console.log(`file: ${latest.filePath}`);
    console.log(`bytes: ${latest.size}`);
    console.log(`estimated_tokens: ${estimateTokens(text)}`);
    console.log(`json: ${parsed ? 'yes' : 'no'}`);
    console.log(`modified_at: ${new Date(latest.mtimeMs).toISOString()}`);
    console.log('');

    if (parsed) {
      const usageObjects = collectUsageObjects(parsed).map(normalizeUsage);
      const messageStats = collectMessageStats(parsed);
      console.log('JSON shape:');
      console.log(summarizeJsonShape(parsed));
      console.log('');
      console.log('Message stats:');
      console.log(`- messages_arrays: ${messageStats.arrays_named_messages}`);
      console.log(`- message_items: ${messageStats.message_items}`);
      console.log(`- roles: ${JSON.stringify(messageStats.roles)}`);
      console.log(`- largest_string_chars: ${messageStats.largest_string_chars}`);
      console.log(`- largest_string_path: ${messageStats.largest_string_path || '(none)'}`);
      console.log('');
      console.log('Usage objects:');
      if (!usageObjects.length) {
        console.log('- (none)');
      } else {
        for (const item of usageObjects.slice(0, 10)) {
          console.log(`- input=${item.input_tokens}, output=${item.output_tokens}, cache_create=${item.cache_creation_tokens}, cache_read=${item.cache_read_tokens}`);
        }
      }
      console.log('');
    }

    console.log('Keyword matches:');
    for (const item of keywordList) {
      const count = text.split(item).length - 1;
      console.log(`- ${item}: ${count}`);
    }

    if (showSnippet && keyword) {
      console.log('');
      console.log('Snippet:');
      console.log(findKeywordSnippet(text, keyword) || '(keyword not found)');
    } else {
      console.log('');
      console.log('Snippet: disabled. Re-run with --keyword <text> --show-snippet to print a short redacted snippet.');
    }
    return;
  }

  if (action === 'stats') {
    printApiProbeStats({ dir, dataDir });
    return;
  }

  console.log('Usage: tokenless api-probe start|stop|inspect|latest|stats [--dir <dir>] [--data-dir <dir>] [--keyword <text>] [--show-snippet]');
}

async function main() {
  const args = process.argv.slice(2);

  if (args[0] === '--help' || args[0] === '-h') {
    usage();
    process.exit(0);
  }

  if (args.length === 0) {
    usage();
    process.exit(1);
  }

  const command = args[0];

  if (command === 'run') {
    const rest = args.slice(1);
    const { agent, dataDir, commandParts, encodedCommand } = parseRunArgs(rest);

    if (!encodedCommand && commandParts.length === 0) {
      console.error('tokenless run missing command after --');
      usage();
      process.exit(1);
    }

    const commandText = encodedCommand || commandParts.join(' ');
    const commandForRun = encodedCommand
      ? { command: process.env.SHELL || '/bin/sh', args: ['-lc', encodedCommand], useShell: false, shellCommand: '' }
      : normalizeCommandArgs(commandParts);
    const result = await runCommand(commandForRun);
    const beforeText = `${result.stdout}\n${result.stderr}`;
    const outputReducer = getReducerForOutput({
      command: commandText,
      stdout: result.stdout,
      stderr: result.stderr
    });

    if (agent && !isNoisyCommand(commandText) && outputReducer === 'bash_generic' && estimateTokens(beforeText) < 8000) {
      if (result.stdout) process.stdout.write(result.stdout);
      if (result.stderr) process.stderr.write(result.stderr);
      process.exit(0);
    }

    const reducer = getReducerForOutput({
      command: commandText,
      stdout: result.stdout,
      stderr: result.stderr
    }) || (isNoisyCommand(commandText) ? 'bash_generic' : getReducerForCommand(commandText));

    const compacted = compactOutput({
      tool: 'Bash',
      command: commandText,
      exitCode: result.code,
      stdout: result.stdout,
      stderr: result.stderr,
      reducer,
      dataDir,
      beforeText: `${result.stdout}\n${result.stderr}`,
      fromPost: false
    });

    const artifact = createArtifact({
      dataDir,
      command: commandText,
      exitCode: result.code,
      reducer,
      stdout: result.stdout,
      stderr: result.stderr,
      compactedText: compacted.text,
      beforeTokens: compacted.beforeTokens,
      afterTokens: compacted.afterTokens,
      status: compacted.status,
      source: process.env.TOKENLESS_STATS_SOURCE || (agent ? 'hook' : 'smoke')
    });

    const outputText = compacted.text.replace(
      'tokenless show null',
      formatArtifactPointer(artifact.artifact_id, {
        accPath: __filename,
        dataDir
      })
    );

    console.log(outputText);
    if (agent) {
      process.exit(0);
    }
    process.exit(result.code || 0);
    return;
  }

  if (command === 'read') {
    const parsed = parseReadArgs(args.slice(1));
    if (!parsed.filePath) {
      console.error('tokenless read requires <file>');
      process.exit(1);
    }

    let text;
    try {
      text = fs.readFileSync(parsed.filePath, 'utf8');
    } catch (err) {
      console.error(`failed to read ${parsed.filePath}: ${err.message}`);
      process.exit(1);
    }

    const beforeTokens = estimateTokens(text);
    if (!shouldCompactRead({ filePath: parsed.filePath, text, tokens: beforeTokens })) {
      process.stdout.write(text);
      process.exit(0);
    }

    const existingPacket = getReadPacketState(parsed.dataDir, parsed.filePath);
    if (existingPacket.status === 'valid' && existingPacket.entry && existingPacket.entry.artifact_id) {
      process.stdout.write(formatReadReusePacket({
        filePath: parsed.filePath,
        dataDir: parsed.dataDir,
        state: existingPacket
      }));
      process.exit(0);
    }

    const artifactId = formatArtifactId();
    const packet = summarizeRead({
      filePath: parsed.filePath,
      text,
      artifactId,
      tokenlessPath: __filename,
      dataDir: parsed.dataDir
    });

    const artifact = createArtifact({
      dataDir: parsed.dataDir,
      artifactId,
      command: `Read ${parsed.filePath}`,
      exitCode: 0,
      reducer: 'read-packet',
      stdout: text,
      stderr: '',
      compactedText: packet.text,
      beforeTokens,
      afterTokens: packet.afterTokens,
      status: 'success',
      source: process.env.TOKENLESS_STATS_SOURCE || (parsed.agent ? 'hook' : 'smoke')
    });

    clearReadGate({ dataDir: parsed.dataDir, filePath: parsed.filePath });
    markReadPacket({
      dataDir: parsed.dataDir,
      filePath: parsed.filePath,
      artifactId: artifact.artifact_id,
      estimatedTokens: beforeTokens
    });
    process.stdout.write(packet.text.replace(`show ${artifactId}`, `show ${artifact.artifact_id}`));
    process.exit(0);
  }

  if (command === 'compact') {
    const parsed = parseCompactArgs(args.slice(1));
    if (!parsed.stdin) {
      console.error('tokenless compact requires --stdin');
      process.exit(1);
    }

    const inputText = fs.readFileSync(0, 'utf8');
    const reducer = parsed.reducer || getReducerForOutput({
      command: parsed.commandLabel,
      stdout: inputText,
      stderr: ''
    });

    const compacted = compactOutput({
      tool: 'stdin',
      command: parsed.commandLabel,
      exitCode: parsed.exitCode,
      stdout: inputText,
      stderr: '',
      reducer,
      dataDir: parsed.dataDir,
      beforeText: inputText
    });

    const artifact = createArtifact({
      dataDir: parsed.dataDir,
      command: parsed.commandLabel,
      exitCode: parsed.exitCode,
      reducer,
      stdout: inputText,
      stderr: '',
      compactedText: compacted.text,
      beforeTokens: compacted.beforeTokens,
      afterTokens: compacted.afterTokens,
      status: compacted.status,
      source: process.env.TOKENLESS_STATS_SOURCE || 'smoke'
    });

    console.log(compacted.text.replace(
      'tokenless show null',
      formatArtifactPointer(artifact.artifact_id, {
        accPath: __filename,
        dataDir: parsed.dataDir
      })
    ));
    process.exit(0);
  }

  if (command === 'list') {
    const parsed = parseListArgs(args.slice(1));
    const artifacts = listArtifacts(parsed.dataDir).slice(0, parsed.limit);

    console.log('TOKENLESS-ARTIFACTS/0.1');
    console.log(`data_dir: ${parsed.dataDir}`);
    console.log(`count: ${artifacts.length}`);
    console.log('');

    if (!artifacts.length) {
      console.log('(no artifacts found)');
      process.exit(0);
    }

    artifacts.forEach((meta, index) => printArtifactSummary(meta, index));
    process.exit(0);
  }

  if (command === 'latest') {
    const parsed = parseDoctorArgs(args.slice(1));
    const latest = listArtifacts(parsed.dataDir)[0];
    if (!latest) {
      console.error(`no artifacts found in ${parsed.dataDir}`);
      process.exit(1);
    }

    console.log('TOKENLESS-LATEST/0.1');
    printArtifactSummary(latest, null);
    console.log(`show: ${formatArtifactPointer(latest.artifact_id, { accPath: __filename, dataDir: parsed.dataDir })}`);
    console.log(`expand: node '${__filename.replace(/'/g, "'\\''")}' expand ${latest.artifact_id} --around "<keyword>" --data-dir '${String(parsed.dataDir).replace(/'/g, "'\\''")}'`);
    process.exit(0);
  }

  if (command === 'stats') {
    const parsed = parseDoctorArgs(args.slice(1));
    printStats(parsed.dataDir);
    process.exit(0);
  }

  if (command === 'api-usage') {
    const parsed = parseApiUsageArgs(args.slice(1));
    printApiUsage(parsed);
    process.exit(0);
  }

  if (command === 'launch' || command === 'claude') {
    launchClaude(args.slice(1));
    return;
  }

  if (command === 'api-probe') {
    const parsed = parseApiProbeArgs(args.slice(1));
    printApiProbe(parsed);
    process.exit(0);
  }

  if (command === 'benchmark-copy') {
    const parsed = parseBenchmarkCopyArgs(args.slice(1));
    benchmarkCopy(parsed);
    process.exit(0);
  }

  if (command === 'print-hooks') {
    const parsed = parseDoctorArgs(args.slice(1));
    printHooks(parsed.dataDir);
    process.exit(0);
  }

  if (command === 'status') {
    const parsed = parseSettingsScopeArgs(args.slice(1));
    if (!['user', 'project'].includes(parsed.scope) && !parsed.settingsPath) {
      console.error('tokenless status requires --user, --project, or --settings <path>');
      process.exit(1);
    }
    printStatus(parsed);
    process.exit(0);
  }

  if (command === 'install-hooks') {
    const parsed = parseInstallHooksArgs(args.slice(1));
    if (!['user', 'project'].includes(parsed.scope) && !parsed.settingsPath) {
      console.error('tokenless install-hooks requires --user, --project, or --settings <path>');
      process.exit(1);
    }
    installHooks(parsed);
    process.exit(0);
  }

  if (command === 'uninstall-hooks') {
    const parsed = parseSettingsScopeArgs(args.slice(1));
    if (!['user', 'project'].includes(parsed.scope) && !parsed.settingsPath) {
      console.error('tokenless uninstall-hooks requires --user, --project, or --settings <path>');
      process.exit(1);
    }
    uninstallHooks(parsed);
    process.exit(0);
  }

  if (command === 'repair-hooks') {
    const flags = new Set(args.slice(1));
    repairHooks({
      user: flags.has('--user') || (!flags.has('--project')),
      project: flags.has('--project'),
      dryRun: flags.has('--dry-run')
    });
    process.exit(0);
  }

  if (command === 'install-commands') {
    const parsed = parseSlashCommandArgs(args.slice(1));
    installSlashCommands(parsed);
    process.exit(0);
  }

  if (command === 'uninstall-commands') {
    const parsed = parseSlashCommandArgs(args.slice(1));
    uninstallSlashCommands(parsed);
    process.exit(0);
  }

  if (command === 'clean') {
    const parsed = parseCleanArgs(args.slice(1));
    cleanArtifacts(parsed);
    process.exit(0);
  }

  if (command === 'doctor') {
    const parsed = parseDoctorArgs(args.slice(1));
    runDoctor(parsed.dataDir);
    process.exit(0);
  }

  if (command === 'show') {
    const parsed = parseShowOrExpandArgs(args.slice(1));
    const artifactId = parsed.positional[0];
    if (!artifactId) {
      console.error('tokenless show missing artifact_id');
      process.exit(1);
    }
    showArtifact(artifactId, parsed.dataDir);
    process.exit(0);
  }

  if (command === 'expand') {
    const parsed = parseShowOrExpandArgs(args.slice(1));
    const artifactId = parsed.positional[0];
    if (!artifactId) {
      console.error('tokenless expand missing artifact_id');
      process.exit(1);
    }
    if (parsed.lines) {
      expandArtifactByLines(artifactId, parsed.lines, parsed.dataDir);
    } else {
      expandArtifact(artifactId, parsed.around, parsed.dataDir);
    }
    process.exit(0);
  }

  usage();
  process.exit(1);
}

main().catch((err) => {
  console.error(err && err.message ? err.message : String(err));
  process.exit(1);
});
