  console.log('  tokenless install-hooks --user|--project [--settings <path>] [--dry-run]');
  console.log('  tokenless uninstall-hooks --user|--project [--settings <path>] [--dry-run]');
  console.log('  tokenless repair-hooks --user [--project] [--dry-run]');
  console.log('  tokenless install-commands [--user] [--data-dir <dir>] [--dry-run]');
  console.log('  tokenless uninstall-commands [--user] [--dry-run]');
  console.log('  tokenless launch [--claude-bin <path>] [--allow-task-tools] [--print] [-- <claude-args...>]');
