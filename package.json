{
  "name": "tokenless",
  "version": "0.1.0",
  "description": "Tokenless context compression for noisy Claude Code tool output",
  "private": true,
  "type": "commonjs",
  "license": "MIT",
  "bin": {
    "acc": "plugins/claude-code/bin/acc",
    "tokenless": "plugins/claude-code/bin/tokenless"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxLiu199909/Tokenless.git"
  },
  "bugs": {
    "url": "https://github.com/MaxLiu199909/Tokenless/issues"
  },
  "homepage": "https://github.com/MaxLiu199909/Tokenless#readme",
  "keywords": [
    "tokenless",
    "claude-code",
    "agent",
    "context",
    "compression",
    "hooks",
    "logs"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "eval": "node evals/run_eval.js",
    "eval:synthetic": "node evals/run_eval.js --synthetic",
    "eval:real": "node evals/run_eval.js --real",
    "eval:all": "node evals/run_eval.js --all",
    "eval:complex": "node evals/run_complex_test_log_case.js",
    "eval:read": "node evals/run_read_eval.js",
    "eval:edit": "node evals/run_edit_eval.js",
    "eval:cli-smoke": "node evals/run_cli_smoke.js",
    "eval:capture": "node evals/capture_real_case.js",
    "eval:generate-real": "node evals/generate_real_cases.js",
    "doctor": "node plugins/claude-code/bin/tokenless doctor --data-dir /tmp/tokenless-doctor",
    "tokenless:status": "node plugins/claude-code/bin/tokenless status --user",
    "tokenless:stats": "node plugins/claude-code/bin/tokenless stats",
    "tokenless:api-usage": "node plugins/claude-code/bin/tokenless api-usage",
    "tokenless:api-usage:24h": "node plugins/claude-code/bin/tokenless api-usage --since 24h",
    "tokenless:api-probe:start": "node plugins/claude-code/bin/tokenless api-probe start",
    "tokenless:api-probe:stats": "node plugins/claude-code/bin/tokenless api-probe stats --dir /Users/mac/.tokenless/api-bodies-realtest",
    "tokenless:real-check": "node scripts/real_check.js",
    "tokenless:status:project": "node plugins/claude-code/bin/tokenless status --project",
    "tokenless:print-hooks": "node plugins/claude-code/bin/tokenless print-hooks",
    "tokenless:install": "node plugins/claude-code/bin/tokenless install-hooks --user",
    "tokenless:install:dry-run": "node plugins/claude-code/bin/tokenless install-hooks --user --dry-run",
    "tokenless:install:project": "node plugins/claude-code/bin/tokenless install-hooks --project",
    "tokenless:install:project:dry-run": "node plugins/claude-code/bin/tokenless install-hooks --project --dry-run",
    "tokenless:install-commands": "node plugins/claude-code/bin/tokenless install-commands --user",
    "tokenless:install-commands:dry-run": "node plugins/claude-code/bin/tokenless install-commands --user --dry-run",
    "tokenless:uninstall-commands": "node plugins/claude-code/bin/tokenless uninstall-commands --user",
    "tokenless:uninstall": "node plugins/claude-code/bin/tokenless uninstall-hooks --user",
    "tokenless:uninstall:dry-run": "node plugins/claude-code/bin/tokenless uninstall-hooks --user --dry-run",
    "tokenless:uninstall:project:dry-run": "node plugins/claude-code/bin/tokenless uninstall-hooks --project --dry-run",
    "tokenless:repair-hooks": "node plugins/claude-code/bin/tokenless repair-hooks --user --project",
    "tokenless:repair-hooks:dry-run": "node plugins/claude-code/bin/tokenless repair-hooks --user --project --dry-run",
    "tokenless:clean:dry-run": "node plugins/claude-code/bin/tokenless clean --keep 100 --dry-run",
    "acc:status": "node plugins/claude-code/bin/tokenless status --user",
    "acc:status:project": "node plugins/claude-code/bin/tokenless status --project",
    "acc:print-hooks": "node plugins/claude-code/bin/tokenless print-hooks",
    "acc:install-hooks": "node plugins/claude-code/bin/tokenless install-hooks --user",
    "acc:install-hooks:dry-run": "node plugins/claude-code/bin/tokenless install-hooks --user --dry-run",
    "acc:install-hooks:project": "node plugins/claude-code/bin/tokenless install-hooks --project",
    "acc:install-hooks:project:dry-run": "node plugins/claude-code/bin/tokenless install-hooks --project --dry-run",
    "acc:uninstall-hooks:dry-run": "node plugins/claude-code/bin/tokenless uninstall-hooks --user --dry-run",
    "acc:uninstall-hooks:project:dry-run": "node plugins/claude-code/bin/tokenless uninstall-hooks --project --dry-run",
    "acc:clean:dry-run": "node plugins/claude-code/bin/tokenless clean --keep 100 --dry-run",
    "test:complex": "node evals/run_complex_test_log_case.js --emit"
  }
}
