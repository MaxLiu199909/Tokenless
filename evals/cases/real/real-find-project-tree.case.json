{
  "name": "real-find-project-tree",
  "command": "find . -maxdepth 4 -type f",
  "exitCode": 0,
  "stdoutFile": "real-find-project-tree.stdout.log",
  "stderrFile": "real-find-project-tree.stderr.log",
  "expectedReducer": "file-tree",
  "mustContain": [
    "Project tree summary:",
    "src/",
    "tests/",
    "Large dirs collapsed:"
  ],
  "mustExpandAround": [
    "src/core/parser.js"
  ],
  "maxTokensAfter": 900,
  "maxRatioPercent": 90,
  "minTokensForRatio": 1000
}
