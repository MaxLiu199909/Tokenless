    "reducer": {"type": "string"},
    "compression_before": {"type": "integer", "minimum": 0},
    "compression_after": {"type": "integer", "minimum": 0},
    "artifact_id": {"type": "string"},
    "key_findings": {"type": "array", "items": {"type": "string"}},
